.softh-slot {
  box-sizing: border-box;
  width: 100%;
  padding: 0 24rpx;
  overflow: hidden;
}

.softh-collapsed {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  box-sizing: border-box;
  background: rgba(217, 234, 243, 0.55);
}

.softh-mini-t {
  font-size: 22rpx;
  color: #5f7380;
}

.softh-inner {
  height: 100%;
  padding: 12rpx 20rpx 16rpx;
  box-sizing: border-box;
  background: rgba(0, 48, 96, 0.08);
  border-radius: 0 0 20rpx 20rpx;
  border: 1rpx solid rgba(0, 48, 96, 0.18);
}

.softh-msg {
  display: block;
  font-size: 24rpx;
  color: #2b3d4a;
  line-height: 1.35;
  margin-bottom: 10rpx;
}

.softh-actions {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 12rpx;
}

.softh-btn {
  margin: 0;
  padding: 0 20rpx;
  line-height: 52rpx;
  border-radius: 26rpx;
  font-size: 22rpx;
}

.softh-btn.prim {
  background: #003060 !important;
  color: #fff !important;
  border: none;
}

.softh-btn.ghost {
  background: rgba(217, 234, 243, 0.9) !important;
  color: #2b3d4a !important;
}

.softh-btn.danger {
  background: rgba(255, 255, 255, 0.85) !important;
  color: #b33a3a !important;
}
