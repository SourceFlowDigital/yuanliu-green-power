<view class="tab-bar">
  <view
    wx:for="{{list}}"
    wx:key="index"
    class="tab-bar-item"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <text
      class="iconfont"
      style="color: {{selected === index ? selectedColor : color}}; font-size: 48rpx;"
    >{{item.unicode}}</text>
    <view style="color: {{selected === index ? selectedColor : color}}; font-size: 20rpx; margin-top: 4rpx;">
      {{item.text}}
    </view>
  </view>
</view>
