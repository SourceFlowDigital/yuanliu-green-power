<view class="tab-shell">
  <view class="tab-inner">
    <view
      class="tab-item"
      wx:for="{{list}}"
      wx:key="url"
      data-index="{{index}}"
      bindtap="switchTab"
    >
      <text
        class="iconfont"
        style="color: {{selected === index ? selectedColor : color}}; font-size: 48rpx;"
      >{{item.unicode}}</text>
      <text
        class="tab-text"
        style="color: {{selected === index ? selectedColor : color}}"
      >{{item.text}}</text>
    </view>
  </view>
</view>
