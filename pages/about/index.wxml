<view class="header">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="header-main" style="height: {{navBarHeight}}px;">
    <image class="header-logo" src="/assets/logo.png" mode="aspectFit"></image>
    <view class="header-title-group">
      <view class="header-title">源流绿电直连</view>
      <view class="header-sub-wrap">
        <text class="header-sub">{{headerSub}}</text>
      </view>
    </view>
  </view>
</view>
<view class="body" style="margin-top: {{headerHeight}}px;">
  <view class="surface-strip">
    <text class="surface-strip-tip">关于平台与服务说明</text>
  </view>
  <view class="policy-list">
    <view wx:for="{{blocks}}" wx:key="title" class="policy-card about-block">
      <view class="card-title">{{item.title}}</view>
      <view class="about-p" wx:for="{{item.lines}}" wx:key="idx" wx:for-item="line" wx:for-index="idx">{{line}}</view>
    </view>
    <view class="policy-card about-actions">
      <view class="card-title">协议</view>
      <view class="action-row" bindtap="toTerms">
        <text class="action-text">《用户协议》</text>
        <text class="action-arrow">›</text>
      </view>
      <view class="action-row" bindtap="toPrivacyDoc">
        <text class="action-text">《隐私政策》</text>
        <text class="action-arrow">›</text>
      </view>
      <view class="action-row" bindtap="openWxPrivacyGuide">
        <text class="action-text">《微信小程序隐私保护指引》</text>
        <text class="action-arrow">›</text>
      </view>
      <view style="margin-top: 24rpx; padding-top: 20rpx; border-top: 1rpx solid #e8edf2; text-align: center;">
        <text style="display: block; font-size: 22rpx; color: #9aa5b4; line-height: 1.8;">© 2026 宁夏源流数字服务有限公司 版权所有</text>
        <navigator url="https://beian.miit.gov.cn" open-type="webview" style="display: block; margin-top: 4rpx;">
          <text style="font-size: 22rpx; color: #9aa5b4;">宁ICP备2026001906号-1</text>
        </navigator>
      </view>
    </view>
  </view>
</view>
