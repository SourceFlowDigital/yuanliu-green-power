@import "../../styles/shell.wxss";

.about-page {
  padding: 20rpx 28rpx;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #F4F8FB;
  min-height: 100vh;
}

/* ===== 通用卡片 ===== */
.about-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 1rpx solid #D9E8FF;
  padding: 32rpx 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 48, 96, 0.05);
  box-sizing: border-box;
}

.about-card-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #003060;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.about-disclaimer-text {
  display: block;
  font-size: 26rpx;
  color: #5E6D7F;
  line-height: 1.85;
  text-indent: 2em;
}

/* ===== 1. 关注我们 ===== */
.about-follow-card {
  text-align: center;
  padding: 36rpx 28rpx 32rpx;
  border: 1rpx solid #C5D9EB;
  background: linear-gradient(180deg, #FAFBFC 0%, #FFFFFF 100%);
}

.follow-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #003060;
  margin-bottom: 20rpx;
}

.follow-wechat-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-bottom: 24rpx;
}

.follow-wechat-icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
}

.follow-wechat-text {
  font-size: 26rpx;
  color: #374151;
}

.follow-qr-img {
  width: 160rpx;
  height: 160rpx;
  display: block;
  margin: 0 auto 18rpx;
}

.follow-qr-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #9CA3AF;
}

/* ===== 2. 联系我们 ===== */
.contact-table {
  display: flex;
  flex-direction: column;
}

.contact-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #F0F4F8;
  gap: 24rpx;
}

.contact-row:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 26rpx;
  color: #9CA3AF;
  flex-shrink: 0;
  width: 72rpx;
}

.contact-value {
  font-size: 26rpx;
  color: #1F2933;
  line-height: 1.5;
  flex: 1;
}

.contact-link {
  color: #3366CC;
}

/* ===== 3. 平台简介 ===== */
.about-desc {
  display: block;
  font-size: 26rpx;
  color: #5E6D7F;
  line-height: 1.85;
  margin-bottom: 24rpx;
}

.about-features {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 4rpx;
}

.about-feature-item {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.6;
  padding-left: 18rpx;
  position: relative;
}

.about-feature-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 12rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #7AAFD4;
}

/* ===== 4. 法律协议 ===== */
.legal-list {
  display: flex;
  flex-direction: column;
}

.legal-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F4F8;
}

.legal-row:last-child {
  border-bottom: none;
}

.legal-text {
  font-size: 28rpx;
  color: #003060;
  flex: 1;
}

.legal-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
  flex-shrink: 0;
}

/* ===== 6. 底部信息 ===== */
.about-footer {
  margin-top: 8rpx;
  padding: 36rpx 16rpx 48rpx;
  text-align: center;
}

.about-footer-divider {
  width: 60rpx;
  height: 2rpx;
  background: #DCE5EF;
  margin: 0 auto 24rpx;
}

.about-footer-text {
  display: block;
  font-size: 22rpx;
  font-weight: 400;
  color: #9CA3AF;
  line-height: 1.8;
}
