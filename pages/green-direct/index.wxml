<view class="page-container">
  <view class="header">
    <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
    <view class="header-main" style="height: {{navBarHeight}}px;">
      <image class="header-logo" src="/assets/logo.png" mode="aspectFit"></image>
      <view class="header-title-group">
        <view class="header-title">源流绿电直连</view>
        <view class="header-sub-wrap">
          <text class="header-sub">政策合规自测工具</text>
        </view>
      </view>
    </view>
  </view>

  <view
    class="progress-bar-wrap"
    wx:if="{{currentScreen > 0}}"
    style="margin-top: {{headerHeight}}px;"
  >
    <view class="progress-track">
      <view class="progress-fill" style="width: {{progressPercent}}%;"></view>
    </view>
    <text class="progress-text">{{progressText}}</text>
  </view>

  <view
    class="screen-wrap {{currentScreen == 0 ? 'screen-wrap-p0' : ''}} {{currentScreen == 5 ? 'screen-wrap-p5' : ''}} {{currentScreen == 6 ? 'screen-wrap-p6' : ''}} {{currentScreen == 7 ? 'screen-wrap-p7' : ''}}"
    style="margin-top: {{currentScreen > 0 ? 0 : headerHeight}}px;"
  >
    <view wx:if="{{currentScreen == 0}}" class="screen screen-p0">
      <view class="p0-title">源流绿电直连 · 项目预评估工具</view>
      <view class="policy-tag-bar p0-tag-bar">
        <text class="policy-tag">发改能源〔2026〕688号</text>
        <text class="policy-tag-sub">2026年5月14日施行</text>
      </view>
      <text class="p0-body">本工具基于《发改能源〔2026〕688号》，帮助您初步判断项目是否符合多用户绿电直连政策要求，并测算三项核心合规指标。</text>
      <view class="p0-section-title">填写完成后将输出：</view>
      <view class="p0-list">
        <text class="p0-list-item">· 项目基本信息汇总</text>
        <text class="p0-list-item">· 三项比例指标测算结果</text>
        <text class="p0-list-item">· 政策符合性初步结论</text>
        <text class="p0-list-item">· 不达标项整改建议</text>
      </view>
      <text class="p0-disclaimer">本工具结果仅供参考，最终以省级能源主管部门审核为准。不收集任何用户数据。</text>
      <view class="btn-start-eval" catchtap="goStart">开始评估 →</view>
    </view>
    <view wx:if="{{currentScreen == 1}}" class="screen screen-p1">
      <view class="p1-title">第一步：基本条件确认</view>
      <text class="p1-sub">以下任一条件不满足，项目不适用本政策</text>
      <view class="precheck-list">
        <view class="precheck-card" wx:for="{{preCheckItems}}" wx:key="key">
          <text class="precheck-text">{{item.text}}</text>
          <view class="precheck-actions">
            <view
              class="precheck-btn precheck-btn-yes {{appState.preCheck[item.key] === true ? 'active-yes' : ''}}"
              catchtap="onPreCheckSelect"
              data-q="{{item.key}}"
              data-value="yes"
            >是</view>
            <view
              class="precheck-btn precheck-btn-no {{appState.preCheck[item.key] === false ? 'active-no' : ''}}"
              catchtap="onPreCheckSelect"
              data-q="{{item.key}}"
              data-value="no"
            >否</view>
          </view>
        </view>
      </view>
    </view>
    <view wx:if="{{currentScreen == 2}}" class="screen screen-p2">
      <view class="p2-title">第二步：注意事项确认</view>
      <text class="p2-sub">以下情况不影响继续填写，但结果页将提示需进一步落实</text>
      <view class="suspect-list">
        <view class="suspect-card" wx:for="{{suspectCheckItems}}" wx:for-item="qitem" wx:key="key">
          <text class="suspect-text">{{qitem.text}}</text>
          <view class="suspect-options">
            <view
              wx:for="{{qitem.options}}"
              wx:for-item="opt"
              wx:key="value"
              class="suspect-opt-btn {{appState.suspectCheck[qitem.key] === opt.value ? 'active-suspect' : ''}}"
              catchtap="onSuspectCheckSelect"
              data-q="{{qitem.key}}"
              data-value="{{opt.value}}"
            >{{opt.label}}</view>
          </view>
        </view>
      </view>
      <text class="suspect-hint" wx:if="{{suspectCheckIncomplete}}">建议全部作答，未作答项结果页将标注待确认</text>
    </view>
    <view wx:if="{{currentScreen == 3}}" class="screen screen-p3">
      <view class="p3-title">第三步：项目类型</view>
      <text class="p3-sub">请选择您的项目基本类型</text>

      <view class="p3-section">
        <text class="p3-question">您的项目是否计划与公共电网保持物理连接？</text>

        <view
          class="p3-type-card {{appState.projectType.gridType === 'grid' ? 'active' : ''}}"
          catchtap="onSelectGridType"
          data-value="grid"
        >
          <view class="p3-card-title">并网型</view>
          <text class="p3-card-desc">与大电网连接，电网作为备用，供电更可靠，需遵守上网电量等合规规则</text>
        </view>

        <view
          class="p3-type-card {{appState.projectType.gridType === 'offgrid' ? 'active' : ''}}"
          catchtap="onSelectGridType"
          data-value="offgrid"
        >
          <view class="p3-card-title">离网型</view>
          <text class="p3-card-desc">完全独立运行，不接入公共电网，全部电量内部自平衡，需自承全部安全风险</text>
        </view>

        <text class="p3-help-link" catchtap="onToggleP3Help">不确定？点此帮我判断</text>
        <view class="p3-help-panel" wx:if="{{p3HelpExpanded}}">
          <text class="p3-help-text">您的项目在新能源发电不足时，是否需要从公共电网购电作为备用？需要 → 建议选并网型；不需要 → 建议选离网型</text>
        </view>
      </view>

      <view class="p3-section" wx:if="{{appState.projectType.gridType}}">
        <text class="p3-question">项目计划投产年份？</text>
        <view class="p3-year-group">
          <view
            class="p3-year-btn {{appState.projectType.targetYear === 'pre2030' ? 'active' : ''}}"
            catchtap="onSelectTargetYear"
            data-value="pre2030"
          >2030年前（含2030年）</view>
          <view
            class="p3-year-btn {{appState.projectType.targetYear === 'post2030' ? 'active' : ''}}"
            catchtap="onSelectTargetYear"
            data-value="post2030"
          >2030年后</view>
        </view>
        <text class="p3-year-note">影响自发自用占总用电量比例门槛：2030年前≥35%，2030年后≥30%</text>
      </view>
    </view>
    <view wx:if="{{currentScreen == 4}}" class="screen screen-p4">
      <view class="p4-title">第四步：项目基本信息</view>

      <view class="p4-field">
        <view class="p4-label">
          <text class="p4-required">*</text>
          <text>项目名称</text>
        </view>
        <input
          class="p4-input"
          placeholder="请输入项目名称"
          value="{{appState.projectInfo.name}}"
          bindinput="onProjectNameInput"
        />
      </view>

      <view class="p4-field">
        <view class="p4-label"><text>所在省份</text></view>
        <picker mode="selector" range="{{provinceList}}" value="{{provinceIndex}}" bindchange="onProvinceChange">
          <view class="p4-picker {{appState.projectInfo.province ? '' : 'p4-picker-placeholder'}}">
            {{appState.projectInfo.province || '请选择省份'}}
          </view>
        </picker>
      </view>

      <view class="p4-ref-card" wx:if="{{appState.projectInfo.province}}">
        <text class="p4-ref-title">参考发电数据</text>
        <text class="p4-ref-line">光伏参考：{{appState.projectInfo.refHours.solar}} h/年</text>
        <text class="p4-ref-line">风电参考：{{appState.projectInfo.refHours.wind}} h/年</text>
        <text class="p4-ref-line">参考电价：{{appState.projectInfo.refPrice}} 元/kWh</text>
        <text class="p4-ref-note">仅供初步测算参考，正式项目以可研为准</text>
      </view>

      <view class="p4-field">
        <view class="p4-label"><text>是否位于认定园区</text></view>
        <view class="p4-yesno-group">
          <view
            class="p4-yesno-btn {{appState.projectInfo.inPark === true ? 'active' : ''}}"
            catchtap="onSelectInPark"
            data-value="yes"
          >是</view>
          <view
            class="p4-yesno-btn {{appState.projectInfo.inPark === false ? 'active' : ''}}"
            catchtap="onSelectInPark"
            data-value="no"
          >否</view>
        </view>
      </view>

      <view class="p4-field" wx:if="{{appState.projectInfo.inPark === true}}">
        <view class="p4-label"><text>园区类型</text></view>
        <view class="p4-park-group">
          <view
            class="p4-park-btn {{appState.projectInfo.parkType === 'industrial' ? 'active' : ''}}"
            catchtap="onSelectParkType"
            data-value="industrial"
          >工业园区</view>
          <view
            class="p4-park-btn {{appState.projectInfo.parkType === 'zeroCarbon' ? 'active' : ''}}"
            catchtap="onSelectParkType"
            data-value="zeroCarbon"
          >零碳园区</view>
          <view
            class="p4-park-btn {{appState.projectInfo.parkType === 'incremental' ? 'active' : ''}}"
            catchtap="onSelectParkType"
            data-value="incremental"
          >增量配电网</view>
        </view>
      </view>

      <view class="p4-field">
        <view class="p4-label"><text>项目主要产业类型（可多选）</text></view>
        <view class="p4-industry-group">
          <view
            wx:for="{{industryList}}"
            wx:key="value"
            class="p4-industry-tag {{industrySelected[item.value] ? 'active' : ''}} {{item.priority ? 'priority' : ''}}"
            catchtap="onToggleIndustry"
            data-value="{{item.value}}"
          >{{item.label}}</view>
        </view>
      </view>
    </view>
    <view wx:if="{{currentScreen == 5}}" class="screen-p5-wrap">
      <view class="p5-page-head">
        <view class="p5-title">第五步：用电用户信息</view>
        <text class="p5-sub">请逐个录入项目内用电用户，每个用户须为独立法人实体</text>
      </view>

      <view class="user-card" wx:for="{{appState.users}}" wx:for-item="user" wx:for-index="uIdx" wx:key="id">
        <view class="user-card-head">
          <text class="user-card-title">用户{{uIdx + 1}}</text>
          <view class="user-card-actions">
            <text class="user-action-btn" catchtap="onCopyUser" data-id="{{user.id}}">复制</text>
            <text
              class="user-action-btn user-action-del"
              wx:if="{{appState.users.length > 1}}"
              catchtap="onDeleteUser"
              data-id="{{user.id}}"
            >删除</text>
          </view>
        </view>

        <view class="user-module">
          <text class="user-module-title">基本信息</text>
          <view class="p4-field user-field">
            <view class="p4-label"><text class="p4-required">*</text><text>用户名称</text></view>
            <input class="p4-input" placeholder="请输入用户名称" value="{{user.name}}" bindinput="onUserInput" data-id="{{user.id}}" data-field="name" />
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text>行业类别</text></view>
            <view class="p4-industry-group">
              <view
                wx:for="{{userIndustryOptions}}"
                wx:for-item="opt"
                wx:key="value"
                class="p4-industry-tag {{user.industry === opt.value ? 'active' : ''}}"
                catchtap="onUserSelect"
                data-id="{{user.id}}"
                data-field="industry"
                data-value="{{opt.value}}"
              >{{opt.label}}</view>
            </view>
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text>是否农业/居民用电</text></view>
            <view class="p4-yesno-group">
              <view class="p4-yesno-btn {{user.isAgriResident === true ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="isAgriResident" data-value="yes">是</view>
              <view class="p4-yesno-btn {{user.isAgriResident === false ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="isAgriResident" data-value="no">否</view>
            </view>
            <text class="user-warn" wx:if="{{user.isAgriResident === true}}">⚠️ 政策明确规定多用户不包括居民和农业用户</text>
          </view>
        </view>

        <view class="user-module">
          <text class="user-module-title">用电数据</text>
          <view class="p4-field user-field">
            <view class="p4-label"><text>主要生产时段</text></view>
            <view class="user-opt-row">
              <view wx:for="{{productionShiftOptions}}" wx:for-item="opt" wx:key="value" class="user-opt-chip {{user.productionShift === opt.value ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="productionShift" data-value="{{opt.value}}">{{opt.label}}</view>
            </view>
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text>主要用电高峰时段</text></view>
            <view class="user-opt-row">
              <view wx:for="{{peakPeriodOptions}}" wx:for-item="opt" wx:key="value" class="user-opt-chip {{user.peakPeriod === opt.value ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="peakPeriod" data-value="{{opt.value}}">{{opt.label}}</view>
            </view>
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text class="p4-required">*</text><text>上一年度用电量（万kWh）</text></view>
            <input class="p4-input" type="digit" placeholder="请输入用电量" value="{{user.annualConsumption}}" bindinput="onUserInput" data-id="{{user.id}}" data-field="annualConsumption" />
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text>是否已收集电费缴费单</text></view>
            <view class="p4-yesno-group">
              <view class="p4-yesno-btn {{user.hasBillData === true ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="hasBillData" data-value="yes">是</view>
              <view class="p4-yesno-btn {{user.hasBillData === false ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="hasBillData" data-value="no">否</view>
            </view>
            <text class="user-hint-orange" wx:if="{{user.hasBillData === false}}">建议收集电费缴费单后填写，数据准确性更高</text>
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text>变压器总容量（kVA）</text></view>
            <input class="p4-input" type="digit" placeholder="选填" value="{{user.transformerCapacity}}" bindinput="onUserInput" data-id="{{user.id}}" data-field="transformerCapacity" />
          </view>
        </view>

        <view class="user-module">
          <text class="user-module-title">扩产计划</text>
          <view class="p4-field user-field">
            <view class="p4-label"><text>是否有扩产/减产计划</text></view>
            <view class="p4-yesno-group">
              <view class="p4-yesno-btn {{user.hasExpansionPlan === true ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="hasExpansionPlan" data-value="yes">是</view>
              <view class="p4-yesno-btn {{user.hasExpansionPlan === false ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="hasExpansionPlan" data-value="no">否</view>
            </view>
          </view>
          <view class="p4-field user-field" wx:if="{{user.hasExpansionPlan === true}}">
            <view class="p4-label"><text>预期年增减率（%/年，可为负）</text></view>
            <input class="p4-input" type="digit" placeholder="如 5 或 -3" value="{{user.expansionRate}}" bindinput="onUserInput" data-id="{{user.id}}" data-field="expansionRate" />
            <text class="user-calc-line">预计2030年用电量：{{user.consumption2030}} 万kWh</text>
          </view>
        </view>

        <view class="user-module">
          <text class="user-module-title">屋顶资源</text>
          <view class="p4-field user-field">
            <view class="p4-label"><text>是否同意建设屋顶光伏</text></view>
            <view class="p4-yesno-group">
              <view class="p4-yesno-btn {{user.hasRooftop === true ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="hasRooftop" data-value="yes">是</view>
              <view class="p4-yesno-btn {{user.hasRooftop === false ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="hasRooftop" data-value="no">否</view>
            </view>
          </view>
          <block wx:if="{{user.hasRooftop === true}}">
            <view class="p4-field user-field">
              <view class="p4-label"><text>屋顶产权方</text></view>
              <input class="p4-input" placeholder="选填" value="{{user.rooftopOwner}}" bindinput="onUserInput" data-id="{{user.id}}" data-field="rooftopOwner" />
            </view>
            <view class="p4-field user-field">
              <view class="p4-label"><text>屋顶结构</text></view>
              <view class="user-opt-row">
                <view wx:for="{{rooftopStructureOptions}}" wx:for-item="opt" wx:key="value" class="user-opt-chip {{user.rooftopStructure === opt.value ? 'active' : ''}}" catchtap="onUserSelect" data-id="{{user.id}}" data-field="rooftopStructure" data-value="{{opt.value}}">{{opt.label}}</view>
              </view>
              <input
                wx:if="{{user.rooftopStructure === '其他'}}"
                class="p4-input user-roof-custom"
                placeholder="请描述屋顶结构"
                value="{{user.rooftopStructureCustom}}"
                bindinput="onUserInput"
                data-id="{{user.id}}"
                data-field="rooftopStructureCustom"
              />
            </view>
            <view class="p4-field user-field">
              <view class="p4-label"><text>预计可安装容量（MW）</text></view>
              <input class="p4-input" type="digit" placeholder="请输入容量" value="{{user.rooftopCapacity}}" bindinput="onUserInput" data-id="{{user.id}}" data-field="rooftopCapacity" />
            </view>
            <view class="p4-field user-field">
              <view class="p4-label"><text>年有效发电小时数（h）</text></view>
              <input class="p4-input" type="digit" value="{{user.rooftopHours}}" bindinput="onUserInput" data-id="{{user.id}}" data-field="rooftopHours" />
            </view>
            <text class="user-calc-line">预计年发电量：{{user.rooftopGeneration}} 万kWh</text>
          </block>
        </view>
      </view>

      <view class="btn-add-user" catchtap="onAddUser">+ 添加用户</view>
    </view>
    <view wx:if="{{currentScreen == 6}}" class="screen-p6-wrap">
      <view class="p6-page-head">
        <view class="p6-title">第六步：新能源电源信息</view>
        <text class="p6-sub">请填写计划配套建设的新能源电源</text>
      </view>

      <view class="p6-rooftop-ref" wx:if="{{p6RooftopRef.show}}">
        <view class="p6-rooftop-ref-text">
          <text>用户侧已录入屋顶光伏：{{p6RooftopRef.total}} MW / {{p6RooftopRef.totalGen}} 万kWh</text>
        </view>
        <view class="p6-rooftop-ref-btn" catchtap="onImportRooftopEnergy">引用</view>
      </view>

      <view class="energy-card" wx:for="{{appState.energySources}}" wx:for-item="es" wx:for-index="eIdx" wx:key="id">
        <view class="user-card-head">
          <text class="user-card-title">电源{{eIdx + 1}}</text>
          <view class="user-card-actions">
            <text class="user-action-btn" catchtap="onCopyEnergySource" data-id="{{es.id}}">复制</text>
            <text
              class="user-action-btn user-action-del"
              wx:if="{{appState.energySources.length > 1}}"
              catchtap="onDeleteEnergySource"
              data-id="{{es.id}}"
            >删除</text>
          </view>
        </view>

        <view class="p4-field user-field">
          <view class="p4-label"><text class="p4-required">*</text><text>电源类型</text></view>
          <view class="user-opt-row">
            <view
              wx:for="{{energyTypeOptions}}"
              wx:for-item="opt"
              wx:key="value"
              class="user-opt-chip {{es.type === opt.value ? 'active' : ''}}"
              catchtap="onEnergySelect"
              data-id="{{es.id}}"
              data-field="type"
              data-value="{{opt.value}}"
            >{{opt.label}}</view>
          </view>
        </view>

        <view class="p4-field user-field">
          <view class="p4-label"><text class="p4-required">*</text><text>装机规模（MW）</text></view>
          <input class="p4-input" type="digit" placeholder="请输入装机规模" value="{{es.capacity}}" bindinput="onEnergyInput" data-id="{{es.id}}" data-field="capacity" />
        </view>

        <view class="p4-field user-field">
          <view class="p4-label"><text>年有效发电小时数（h）</text></view>
          <view class="es-hours-row">
            <input class="p4-input es-hours-input" type="digit" value="{{es.hours}}" bindinput="onEnergyInput" data-id="{{es.id}}" data-field="hours" />
            <text class="es-hours-tag" wx:if="{{!es.hoursCustom}}">参考值</text>
            <text class="es-hours-tag es-hours-tag-custom" wx:else>已自定义</text>
          </view>
        </view>

        <text class="user-calc-line">预计年发电量：{{es.generation}} 万kWh</text>

        <view class="p4-field user-field">
          <view class="p4-label"><text>是否存量项目</text></view>
          <view class="user-opt-row">
            <view
              wx:for="{{existingProjectOptions}}"
              wx:for-item="opt"
              wx:key="value"
              class="user-opt-chip {{es.isExisting === opt.value ? 'active' : ''}}"
              catchtap="onEnergySelect"
              data-id="{{es.id}}"
              data-field="isExisting"
              data-value="{{opt.value}}"
            >{{opt.label}}</view>
          </view>
          <text class="user-hint-orange" wx:if="{{es.isExisting === 'existingUngrid' || es.isExisting === 'existingLimited'}}">需在履行相应变更手续后方可开展直连</text>
        </view>
      </view>

      <view class="btn-add-user" catchtap="onAddEnergySource">+ 添加电源</view>
    </view>
    <view wx:if="{{currentScreen == 7}}" class="screen screen-p7-balance">
      <view class="p7-balance-title">第七步：源荷平衡分析</view>

      <view class="p7-balance-card">
        <view class="p7-balance-card-title">用电端</view>
        <text class="p7-balance-line">用户总数：{{p7Balance.userCount}} 个</text>
        <text class="p7-balance-line">年总用电量：{{p7Balance.totalConsumption}} 万kWh</text>
        <text class="p7-balance-line">预计2030年总用电量：{{p7Balance.consumption2030}} 万kWh</text>
      </view>

      <view class="p7-balance-card">
        <view class="p7-balance-card-title">发电端</view>
        <block wx:for="{{p7Balance.p7ByTypeList}}" wx:key="type">
          <text class="p7-balance-line">{{item.label}}：{{item.capacity}} MW / {{item.generation}} 万kWh</text>
        </block>
        <text class="p7-balance-line p7-balance-total">合计：{{p7Balance.totalCapacity}} MW / {{p7Balance.totalGeneration}} 万kWh</text>
      </view>

      <view class="p7-balance-card">
        <view class="p7-balance-card-title">平衡分析</view>
        <view class="p7-balance-gap-row">
          <text class="p7-balance-label">发电量与用电量差值：</text>
          <text class="p7-balance-gap p7-balance-gap-{{p7Balance.gapKind}}" wx:if="{{p7Balance.gapKind === 'surplus'}}">+{{p7Balance.gapAbs}} 万kWh（发电过剩）</text>
          <text class="p7-balance-gap p7-balance-gap-{{p7Balance.gapKind}}" wx:elif="{{p7Balance.gapKind === 'short'}}">{{p7Balance.gapAbs}} 万kWh（存在缺口）</text>
          <text class="p7-balance-gap p7-balance-gap-{{p7Balance.gapKind}}" wx:else>基本匹配</text>
        </view>
        <text class="p7-balance-line">初步自发自用电量：{{p7Balance.selfUse}} 万kWh</text>
        <view class="p7-balance-metric-row">
          <text class="p7-balance-label">指标一预估（自发自用/总发电量）：</text>
          <text class="p7-balance-metric-val {{p7Balance.ratio1Pass ? 'pass' : 'fail'}}">{{p7Balance.ratio1}}%</text>
        </view>
        <text class="p7-balance-hint">达标门槛 ≥60%</text>
        <view class="p7-balance-metric-row">
          <text class="p7-balance-label">指标二预估（自发自用/总用电量）：</text>
          <text class="p7-balance-metric-val {{p7Balance.ratio2Pass ? 'pass' : 'fail'}}">{{p7Balance.ratio2}}%</text>
        </view>
        <text class="p7-balance-hint">门槛说明：2030年前≥35%，2030年后≥30%</text>
      </view>

      <view class="p7-conclusion p7-conclusion-pass" wx:if="{{p7Balance.conclusionType === 'pass'}}">
        <text>源荷匹配良好，可根据投资意愿决定是否配置储能</text>
      </view>
      <view class="p7-conclusion p7-conclusion-warn" wx:elif="{{p7Balance.conclusionType === 'failRatio1'}}">
        <text>自发自用比例偏低，建议减少新能源装机或增加用电负荷</text>
      </view>
      <view class="p7-conclusion p7-conclusion-warn" wx:elif="{{p7Balance.conclusionType === 'failRatio2'}}">
        <text>绿电消费比例偏低，建议增加内部用电量或减少新能源装机</text>
      </view>
      <view class="p7-conclusion p7-conclusion-fail" wx:else>
        <text>源荷匹配不足，建议调整新能源装机规模后重新测算</text>
      </view>

      <view class="p7-ai-section">
        <view class="p7-ai-title">AI深度解读</view>
        <view wx:if="{{!p7Balance.aiContent && !p7Balance.aiLoading && !p7Balance.aiError}}">
          <view class="p7-ai-btn" catchtap="onGetAIAnalysis">获取AI分析建议</view>
        </view>
        <text class="p7-ai-loading" wx:elif="{{p7Balance.aiLoading}}">AI分析中，请稍候...</text>
        <text class="p7-ai-content" wx:elif="{{p7Balance.aiContent}}">{{p7Balance.aiContent}}</text>
        <view wx:else class="p7-ai-error-wrap">
          <text class="p7-ai-error">AI分析暂时不可用，请稍后重试</text>
          <view class="p7-ai-retry" catchtap="onGetAIAnalysis">重试</view>
        </view>
      </view>

      <view class="p7-disclaimer-card">
        <view class="p7-disclaimer-title">⚠️ 分析说明</view>
        <text class="p7-disclaimer-body">本页仅从电量总量角度进行简单平衡估算，未考虑电源出力曲线与用电负荷曲线的时序匹配，也未考虑发用电峰谷特性对平衡结果的影响。如需进行多维度系统平衡分析，获取最优配置方案，建议委托具备相应资质的设计单位开展全系统仿真模拟计算。</text>
      </view>
    </view>
    <view wx:if="{{currentScreen == 8}}" class="screen screen-p7">
      <view class="p7-title">第八步：储能配置</view>

      <view class="p7-analysis-card">
        <text class="p7-analysis-line">新能源预计年总发电量：{{p7Preview.totalGeneration}} 万kWh</text>
        <text class="p7-analysis-line">用户预计年总用电量：{{p7Preview.totalConsumption}} 万kWh</text>
        <view class="p7-gap-row">
          <text class="p7-analysis-label">初步消纳缺口：</text>
          <text class="p7-gap-text p7-gap-{{p7Preview.gapKind}}" wx:if="{{p7Preview.gapKind === 'surplus'}}">发电过剩 {{p7Preview.gapAbs}} 万kWh</text>
          <text class="p7-gap-text p7-gap-{{p7Preview.gapKind}}" wx:elif="{{p7Preview.gapKind === 'short'}}">发电不足 {{p7Preview.gapAbs}} 万kWh</text>
          <text class="p7-gap-text p7-gap-{{p7Preview.gapKind}}" wx:else>发电量与用电量基本匹配</text>
        </view>
      </view>

      <view class="p7-metric-card">
        <text class="p7-metric-title">配储前指标预估</text>
        <view class="p7-metric-row">
          <text class="p7-metric-label">指标一（自发自用/总发电量）</text>
          <text class="p7-metric-val {{p7Preview.ratio1Before >= 60 ? 'pass' : 'fail'}}">{{p7Preview.ratio1Before}}%</text>
        </view>
        <text class="p7-metric-hint">门槛 ≥60%</text>
        <view class="p7-metric-row">
          <text class="p7-metric-label">指标二（自发自用/总用电量）</text>
          <text class="p7-metric-val {{p7Preview.ratio2Before >= p7Preview.ratio2Threshold ? 'pass' : 'fail'}}">{{p7Preview.ratio2Before}}%</text>
        </view>
        <text class="p7-metric-hint">门槛 ≥{{p7Preview.ratio2Threshold}}%</text>
      </view>

      <view class="p4-field">
        <view class="p4-label"><text>是否配置储能</text></view>
        <view class="p4-yesno-group">
          <view
            class="p4-yesno-btn {{appState.storage.hasStorage === true ? 'active' : ''}}"
            catchtap="onSelectHasStorage"
            data-value="yes"
          >是</view>
          <view
            class="p4-yesno-btn {{appState.storage.hasStorage === false ? 'active' : ''}}"
            catchtap="onSelectHasStorage"
            data-value="no"
          >否</view>
        </view>
      </view>

      <block wx:if="{{appState.storage.hasStorage === true}}">
        <view class="p7-storage-panel">
          <view class="p4-field user-field">
            <view class="p4-label"><text>储能功率（MW）</text></view>
            <input class="p4-input" type="digit" placeholder="请输入功率" value="{{appState.storage.power}}" bindinput="onStorageInput" data-field="power" />
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text>储能容量（MWh）</text></view>
            <input class="p4-input" type="digit" placeholder="请输入容量" value="{{appState.storage.capacity}}" bindinput="onStorageInput" data-field="capacity" />
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text>日均充放电次数</text></view>
            <view class="p7-cycles-row">
              <view class="p7-cycles-btn" catchtap="onStorageCyclesChange" data-delta="-0.5">-</view>
              <text class="p7-cycles-val">{{appState.storage.cyclesPerDay}} 次</text>
              <view class="p7-cycles-btn" catchtap="onStorageCyclesChange" data-delta="0.5">+</view>
            </view>
          </view>
          <view class="p4-field user-field">
            <view class="p4-label"><text>年运行天数（天）</text></view>
            <view class="p7-cycles-row">
              <view class="p7-cycles-btn" catchtap="onStorageOperateDaysChange" data-delta="-10">-</view>
              <text class="p7-cycles-val">{{appState.storage.operateDays}} 天</text>
              <view class="p7-cycles-btn" catchtap="onStorageOperateDaysChange" data-delta="10">+</view>
            </view>
            <text class="p7-days-hint">含年度停电检修时间，默认300天</text>
          </view>
          <text class="user-calc-line">预计年增加自发自用电量：{{p7Preview.annualStorageEnergy}} 万kWh</text>
        </view>

        <view class="p7-metric-card" wx:if="{{appState.storage.capacity}}">
          <text class="p7-metric-title">配储后指标预估</text>
          <view class="p7-metric-row">
            <text class="p7-metric-label">配储后指标一</text>
            <text class="p7-metric-val {{p7Preview.ratio1After >= 60 ? 'pass' : 'fail'}}">{{p7Preview.ratio1After}}%</text>
          </view>
          <view class="p7-metric-row">
            <text class="p7-metric-label">配储后指标二</text>
            <text class="p7-metric-val {{p7Preview.ratio2After >= p7Preview.ratio2Threshold ? 'pass' : 'fail'}}">{{p7Preview.ratio2After}}%</text>
          </view>
        </view>
      </block>

      <text class="p7-footnote">储能按1充1放估算，充电电源为新能源发电，放电对象为用户负荷，实际效果受运行策略影响。</text>
    </view>
    <view wx:if="{{currentScreen == 9}}" class="screen">
      <text>P9：汇总（待实现）</text>
    </view>
    <view wx:if="{{currentScreen == 10}}" class="screen">
      <text>P10：结果输出（T12实现）</text>
    </view>
  </view>

  <view class="bottom-nav bottom-nav--single" wx:if="{{currentScreen == 1}}">
    <view
      class="nav-btn nav-btn-next nav-btn-next-only {{preCheckDone ? '' : 'nav-btn-disabled'}}"
      catchtap="goNext"
    >下一项</view>
  </view>

  <view class="reject-modal-mask" wx:if="{{showRejectModal}}">
    <view class="reject-modal">
      <view class="reject-modal-title">⚠️ 不符合准入条件</view>
      <text class="reject-modal-msg">{{rejectMsg}}</text>
      <view class="reject-modal-actions">
        <view class="reject-btn reject-btn-outline" catchtap="onRejectRetry">重新确认</view>
        <view class="reject-btn reject-btn-danger" catchtap="onRejectExit">退出评估</view>
      </view>
    </view>
  </view>

  <view class="p6-summary-bar" wx:if="{{currentScreen == 6}}">
    <view class="p6-summary-panel">
      <view class="p6-summary-total">
        <text class="p6-summary-line">新能源合计装机：{{p6Summary.totalCapacity}} MW</text>
        <text class="p6-summary-line">预计年总发电量：{{p6Summary.totalGeneration}} 万kWh</text>
      </view>
      <view class="p6-summary-bytype" wx:if="{{p6Summary.byType.length}}">
        <view class="p6-type-row" wx:for="{{p6Summary.byType}}" wx:key="type">
          <text>{{item.label}}：{{item.capacity}} MW / {{item.generation}} 万kWh</text>
        </view>
      </view>
    </view>
  </view>

  <view class="p5-summary-bar" wx:if="{{currentScreen == 5}}">
    <view class="p5-summary-grid">
      <view class="p5-summary-item"><text class="p5-summary-label">用户总数</text><text class="p5-summary-val">{{p5Summary.userCount}}</text></view>
      <view class="p5-summary-item"><text class="p5-summary-label">上年总用电</text><text class="p5-summary-val">{{p5Summary.totalAnnual}}万kWh</text></view>
      <view class="p5-summary-item"><text class="p5-summary-label">2030总用电</text><text class="p5-summary-val">{{p5Summary.total2030}}万kWh</text></view>
      <view class="p5-summary-item"><text class="p5-summary-label">屋顶光伏合计</text><text class="p5-summary-val">{{p5Summary.totalRooftop}}万kWh</text></view>
    </view>
  </view>

  <view class="bottom-nav" wx:if="{{currentScreen >= 2}}">
    <view class="nav-btn nav-btn-prev" catchtap="goPrev">上一项</view>
    <text class="nav-page-num">{{currentScreen}}/10</text>
    <view
      class="nav-btn nav-btn-next {{(currentScreen == 3 && !p3Done) || (currentScreen == 4 && !p4Done) || (currentScreen == 5 && !p5Done) || (currentScreen == 6 && !p6Done) ? 'nav-btn-disabled' : ''}}"
      catchtap="goNext"
    >{{currentScreen == 10 ? '完成' : '下一项'}}</view>
  </view>

  <view class="footer-credit {{currentScreen == 0 ? 'footer-credit-p0' : ''}}">
    <text>源流 · 基于发改能源〔2026〕688号</text>
  </view>
</view>
