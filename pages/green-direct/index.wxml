    <view wx:if="{{currentScreen == 10}}" class="screen screen-p10">
      <view class="p10-title">第十步：测算结果</view>

      <view class="p10-banner p10-banner-pass" wx:if="{{finalResults.overallPass}}">
        <text class="p10-banner-main">✅ 三项指标测算结果满足688号文门槛要求</text>
        <text class="p10-banner-sub">建议推进可行性研究（测算结果仅供参考，以审批为准）</text>
      </view>
      <view class="p10-banner p10-banner-fail" wx:else>
        <text class="p10-banner-main">⚠️ 存在指标未满足688号文门槛，建议调整后重新测算</text>
      </view>
      <view class="p10-disclaimer-top">
        <text>⚠️ 本结果基于用户输入数据测算，仅供参考，不构成行政审批结论或投资建议。最终结果以当地省级能源主管部门正式审批为准。</text>
      </view>

      <view class="p10-metrics">
        <view class="p10-metric-card">
          <text class="p10-metric-name">指标一</text>
          <text class="p10-metric-desc">自发自用/总发电量</text>
          <text class="p10-metric-val {{finalResults.ratio1Pass ? 'pass' : 'fail'}}">{{finalResults.ratio1}}%</text>
          <text class="p10-metric-threshold">门槛 ≥60%</text>
        </view>
        <view class="p10-metric-card">
          <text class="p10-metric-name">指标二</text>
          <text class="p10-metric-desc">自发自用/总用电量</text>
          <text class="p10-metric-val {{finalResults.ratio2Pass ? 'pass' : 'fail'}}">{{finalResults.ratio2}}%</text>
          <text class="p10-metric-threshold">门槛 ≥{{finalResults.ratio2Threshold}}%</text>
        </view>
        <view class="p10-metric-card {{finalResults.isOffgrid ? 'p10-metric-card--muted' : ''}}">
          <text class="p10-metric-name">指标三</text>
          <text class="p10-metric-desc">上网电量/总发电量</text>
          <text class="p10-metric-val p10-metric-na" wx:if="{{finalResults.isOffgrid}}">—</text>
          <text class="p10-metric-val {{finalResults.ratio3Pass ? 'pass' : 'fail'}}" wx:else>{{finalResults.ratio3}}%</text>
          <text class="p10-metric-threshold" wx:if="{{finalResults.isOffgrid}}">离网型不涉及</text>
          <text class="p10-metric-threshold" wx:else>门槛 ≤20%</text>
        </view>
      </view>

      <view class="p10-section" wx:if="{{!finalResults.overallPass && finalResults.suggestions.length}}">
        <view class="p10-section-title">💡 优化建议</view>
        <text class="p10-suggest-item" wx:for="{{finalResults.suggestions}}" wx:key="index">{{item.index}}. {{item.text}}</text>
      </view>

      <view class="p10-section">
        <view class="p10-section-title">⚠️ 待落实事项</view>
        <text class="p10-line-ok" wx:if="{{p10SuspectAllClear}}">无待落实事项</text>
        <block wx:else>
          <text class="p10-warn-item" wx:for="{{p10SuspectWarnings}}" wx:key="key">⚠️ {{item.warnMsg}}</text>
        </block>
      </view>

      <view class="p10-priority" wx:if="{{p10ShowPriority}}">
        <text>🌟 您的项目包含政策优先支持产业：{{p10PriorityText}}</text>
      </view>

      <view class="p10-report-section">
        <view class="p10-section-title">选择报告类型</view>

        <view class="p10-report-card">
          <view class="p10-report-head">
            <text class="p10-report-title">📄 基础测算报告</text>
            <text class="p10-tag p10-tag-free">免费</text>
          </view>
          <text class="p10-report-desc">包含项目信息、指标测算结果、风险等级及优化建议</text>
          <view class="p10-btn p10-btn-primary" catchtap="onGenerateReport">生成基础报告</view>
        </view>

        <view class="p10-report-card p10-report-card--ai">
          <view class="p10-report-head">
            <text class="p10-report-title">🤖 AI深度分析报告</text>
            <text class="p10-tag p10-tag-paid">增值服务</text>
          </view>
          <text class="p10-report-desc">在基础报告基础上，增加基于688号文的专业政策解读和项目优化建议</text>
          <view class="p10-ai-pay-card">
            <view class="p10-ai-pay-row">
              <text class="p10-ai-pay-label">🤖 AI深度分析报告</text>
              <text class="p10-ai-pay-price">¥1.99</text>
            </view>
            <text class="p10-ai-pay-desc">基于688号文专业政策解读，输出优化建议与风险提示</text>
            <view class="p10-btn p10-btn-gold" catchtap="onRequestAIReport">立即购买 AI 分析报告</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="bottom-nav bottom-nav--single" wx:if="{{currentScreen == 1}}">
    <view
      class="nav-btn nav-btn-next nav-btn-next-only {{preCheckDone ? '' : 'nav-btn-disabled'}}"
      catchtap="goNext"
    >下一项</view>
  </view>

  <view class="reject-modal-mask" wx:if="{{showRejectModal}}">
    <view class="reject-modal">
      <view class="reject-modal-title">⚠️ 不符合准入条件</view>
      <text class="reject-modal-msg">{{rejectMsg}}</text>
      <view class="reject-modal-actions">
        <view class="reject-btn reject-btn-outline" catchtap="onRejectRetry">重新确认</view>
        <view class="reject-btn reject-btn-danger" catchtap="onRejectExit">退出评估</view>
      </view>
    </view>
  </view>

  <view class="p6-summary-bar" wx:if="{{currentScreen == 6}}">
    <view class="p6-summary-panel">
      <view class="p6-summary-total">
        <text class="p6-summary-line">新能源合计装机：{{p6Summary.totalCapacity}} MW</text>
        <text class="p6-summary-line">预计年总发电量：{{p6Summary.totalGeneration}} 万kWh</text>
      </view>
      <view class="p6-summary-bytype" wx:if="{{p6Summary.byType.length}}">
        <view class="p6-type-row" wx:for="{{p6Summary.byType}}" wx:key="type">
          <text>{{item.label}}：{{item.capacity}} MW / {{item.generation}} 万kWh</text>
        </view>
      </view>
    </view>
  </view>

  <view class="p5-summary-bar" wx:if="{{currentScreen == 5}}">
    <view class="p5-summary-grid">
      <view class="p5-summary-item"><text class="p5-summary-label">用户总数</text><text class="p5-summary-val">{{p5Summary.userCount}}</text></view>
      <view class="p5-summary-item"><text class="p5-summary-label">上年总用电</text><text class="p5-summary-val">{{p5Summary.totalAnnual}}万kWh</text></view>
      <view class="p5-summary-item"><text class="p5-summary-label">2030总用电</text><text class="p5-summary-val">{{p5Summary.total2030}}万kWh</text></view>
      <view class="p5-summary-item"><text class="p5-summary-label">屋顶光伏合计</text><text class="p5-summary-val">{{p5Summary.totalRooftop}}万kWh</text></view>
    </view>
  </view>

  <view class="bottom-nav" wx:if="{{currentScreen >= 2}}" style="{{currentScreen == 10 ? 'justify-content: center' : ''}}">
    <view class="nav-btn nav-btn-prev" catchtap="goPrev">上一项</view>
    <text class="nav-page-num" wx:if="{{currentScreen != 10}}">{{currentScreen}}/10</text>
    <view
      wx:if="{{currentScreen != 10}}"
      class="nav-btn nav-btn-next {{(currentScreen == 3 && !p3Done) || (currentScreen == 4 && !p4Done) || (currentScreen == 5 && !p5Done) || (currentScreen == 6 && !p6Done) ? 'nav-btn-disabled' : ''}}"
      catchtap="goNext"
    >下一项</view>
  </view>

  <view class="footer-credit {{currentScreen == 0 ? 'footer-credit-p0' : ''}}">
    <text>源流 · 基于发改能源〔2026〕688号</text>
  </view>

  <!-- 隐私授权弹窗（首次启动阻断） -->
  <view class="consent-mask" wx:if="{{!userConsent}}">
    <view class="consent-modal">
      <view class="consent-title">欢迎使用源流绿电直连</view>
      <view class="consent-desc">
        <text>本工具基于发改能源〔2026〕688号，提供绿电直连项目数据测算与AI辅助风险分析服务。</text>
      </view>
      <view class="consent-desc">
        <text>使用前请阅读并同意以下协议：</text>
      </view>
      <view class="consent-links">
        <text class="consent-link" catchtap="onOpenTerms">《用户服务协议》</text>
        <text class="consent-link" catchtap="onOpenPrivacy">《隐私政策》</text>
      </view>
      <view class="consent-info">
        <text>· 我们收集您填写的项目数据用于AI分析</text>
        <text>· 不收集通讯录、相册、位置等个人信息</text>
        <text>· 测算结果仅供参考，不构成审批意见</text>
      </view>
      <view class="consent-actions">
        <view class="consent-btn consent-btn-deny" catchtap="onDenyConsent">不同意</view>
        <view class="consent-btn consent-btn-agree" catchtap="onAgreeConsent">同意并继续</view>
      </view>
    </view>
  </view>
</view>
