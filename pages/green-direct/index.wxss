  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 48, 96, 0.06);
}
.p8-compare-table {
  overflow: hidden;
  border-radius: 8rpx;
}
.p8-compare-row {
  display: flex;
  align-items: center;
  border-bottom: 1rpx solid #E8EEF2;
}
.p8-compare-row:last-child {
  border-bottom: none;
}
.p8-compare-head {
  background: #F4F8FB;
}
.p8-compare-head .p8-compare-cell {
  font-weight: 600;
  color: #003060;
}
.p8-compare-cell {
  flex: 1;
  padding: 20rpx 12rpx;
  font-size: 24rpx;
  text-align: center;
  box-sizing: border-box;
}
.p8-compare-label {
  flex: 1.4;
  text-align: left;
  padding-left: 20rpx;
  color: #333;
  font-size: 22rpx;
}
.p8-compare-before {
  color: #666666;
}
.p8-compare-after.pass {
  color: #2E7D32;
  font-weight: 600;
}
.p8-compare-after.fail {
  color: #C62828;
  font-weight: 600;
}
