@import "/styles/shell.wxss";

.policy-tag-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 18rpx 32rpx 10rpx;
}

.policy-tag {
  background: #D9EAF3;
  color: #003060;
  border-radius: 4rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  line-height: 1.5;
}

.policy-tag-sub {
  color: #6B7280;
  font-size: 22rpx;
  line-height: 1.5;
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx 12rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #DCE5EF;
  color: #6B7280;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  flex-shrink: 0;
}

.step-dot.active {
  background: #003060;
  color: #fff;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #DCE5EF;
  max-width: 60rpx;
}

.step-card {
  margin-bottom: 0;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #DCE5EF;
  border-left: 8rpx solid #7AAFD4;
  box-shadow: 0 4rpx 18rpx rgba(0, 48, 96, 0.045);
}

.step-card-header {
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 8rpx;
}

.card-step-label {
  flex-shrink: 0;
  color: #003060;
  background: #D9EAF3;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.step-card-title {
  margin-bottom: 0;
}

.input-row {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(220, 229, 239, 0.9);
}

.input-row-last {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #1F2933;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.input-field {
  width: 100%;
  height: 72rpx;
  background: #F4F8FB;
  border: 1rpx solid #DCE5EF;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1F2933;
  box-sizing: border-box;
}

.radio-group {
  display: flex;
  gap: 16rpx;
}

.radio-item {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  border: 1rpx solid #DCE5EF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #6B7280;
  background: #F4F8FB;
  box-sizing: border-box;
}

.radio-item.active {
  border-color: #003060;
  background: #003060;
  color: #fff;
  font-weight: 600;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 28rpx;
  border: 1rpx solid #DCE5EF;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
  background: #F4F8FB;
  box-sizing: border-box;
}

.tag-item.active {
  border-color: #003060;
  background: #003060;
  color: #fff;
  font-weight: 600;
}

.action-bar {
  padding: 10rpx 32rpx 40rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  margin: 0;
  background: #003060;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 48, 96, 0.22);
}

.btn-primary::after {
  border: none;
}

/* 进度条 */
.progress-bar-wrap { padding: 12rpx 32rpx 0; }
.progress-track { height: 6rpx; background: #E0E8F0; border-radius: 3rpx; }
.progress-fill { height: 6rpx; background: #003060; border-radius: 3rpx; transition: width 0.3s; }
.progress-text { font-size: 22rpx; color: #666; margin-top: 8rpx; display: block; }

/* screen容器 */
.screen-wrap {
  padding: 24rpx 32rpx;
  padding-bottom: calc(300rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(300rpx + env(safe-area-inset-bottom));
}
.screen { background: #fff; border-radius: 8rpx; border-left: 6rpx solid #003060; padding: 32rpx; box-shadow: 0 2rpx 12rpx rgba(0,48,96,0.06); }

.screen-wrap-p0 {
  padding-bottom: calc(160rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* P0 说明页 */
.screen-p0 { border-left-width: 8rpx; }
.p0-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #003060;
  line-height: 1.45;
  margin-bottom: 20rpx;
}
.p0-tag-bar { padding: 0 0 24rpx; }
.p0-body {
  display: block;
  font-size: 28rpx;
  color: #1F2933;
  line-height: 1.75;
  margin-bottom: 28rpx;
}
.p0-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2933;
  margin-bottom: 16rpx;
}
.p0-list { margin-bottom: 28rpx; }
.p0-list-item {
  display: block;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.7;
  padding-left: 8rpx;
}
.p0-disclaimer {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  line-height: 1.65;
  margin-bottom: 36rpx;
}
.btn-start-eval {
  width: 100%;
  height: 88rpx;
  background: #003060;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 48, 96, 0.22);
}

/* P1 前置否决筛查 */
.screen-p1 { padding: 28rpx 28rpx 32rpx; }
.p1-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #003060;
  line-height: 1.4;
  margin-bottom: 12rpx;
}
.p1-sub {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
  margin-bottom: 24rpx;
}
.precheck-list { margin-top: 8rpx; }
.precheck-card {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: #F8FAFC;
  border-radius: 8rpx;
  border: 1rpx solid #E0E8F0;
  box-sizing: border-box;
}
.precheck-text {
  flex: 1;
  font-size: 26rpx;
  color: #1F2933;
  line-height: 1.55;
}
.precheck-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  flex-shrink: 0;
}
.precheck-btn {
  width: 72rpx;
  height: 56rpx;
  border: 2rpx solid #DCE5EF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #6B7280;
  background: #fff;
  box-sizing: border-box;
}
.precheck-btn.active-yes {
  background: #1a7c6e;
  border-color: #1a7c6e;
  color: #fff;
  font-weight: 600;
}
.precheck-btn.active-no {
  background: #C0392B;
  border-color: #C0392B;
  color: #fff;
  font-weight: 600;
}

/* P2 存疑项确认 */
.screen-p2 { padding: 28rpx 28rpx 32rpx; }
.p2-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #003060;
  line-height: 1.4;
  margin-bottom: 12rpx;
}
.p2-sub {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
  margin-bottom: 24rpx;
}
.suspect-list { margin-top: 8rpx; }
.suspect-card {
  padding: 24rpx 20rpx;
  margin-bottom: 16rpx;
  background: #F8FAFC;
  border-radius: 8rpx;
  border: 1rpx solid #E0E8F0;
  box-sizing: border-box;
}
.suspect-text {
  display: block;
  font-size: 26rpx;
  color: #1F2933;
  line-height: 1.55;
  margin-bottom: 20rpx;
}
.suspect-options {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 12rpx;
}
.suspect-opt-btn {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 12rpx;
  border: 2rpx solid #DCE5EF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6B7280;
  background: #fff;
  box-sizing: border-box;
  text-align: center;
}
.suspect-opt-btn.active-suspect {
  background: #D6A84F;
  border-color: #D6A84F;
  color: #fff;
  font-weight: 600;
}
.suspect-hint {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  line-height: 1.5;
  margin-top: 8rpx;
  text-align: center;
}

/* P3 项目类型 */
.screen-p3 { padding: 28rpx 28rpx 32rpx; }
.p3-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #003060;
  line-height: 1.4;
  margin-bottom: 12rpx;
}
.p3-sub {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
  margin-bottom: 28rpx;
}
.p3-section { margin-bottom: 28rpx; }
.p3-question {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1F2933;
  line-height: 1.5;
  margin-bottom: 20rpx;
}
.p3-type-card {
  background: #fff;
  border: 1rpx solid #E0E8F0;
  border-left: 6rpx solid #DCE5EF;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}
.p3-type-card.active {
  border: 2rpx solid #003060;
  border-left: 8rpx solid #003060;
  background: #F0F4FA;
}
.p3-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #003060;
  margin-bottom: 12rpx;
}
.p3-card-desc {
  display: block;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}
.p3-help-link {
  display: block;
  font-size: 24rpx;
  color: #003060;
  text-decoration: underline;
  margin-top: 8rpx;
  padding: 8rpx 0;
}
.p3-help-panel {
  margin-top: 12rpx;
  padding: 20rpx 24rpx;
  background: #F4F6F8;
  border-radius: 8rpx;
}
.p3-help-text {
  display: block;
  font-size: 24rpx;
  color: #5E6D7F;
  line-height: 1.65;
}
.p3-year-group {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.p3-year-btn {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 12rpx;
  border: 2rpx solid #DCE5EF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #6B7280;
  background: #fff;
  text-align: center;
  box-sizing: border-box;
}
.p3-year-btn.active {
  background: #003060;
  border-color: #003060;
  color: #fff;
  font-weight: 600;
}
.p3-year-note {
  display: block;
  font-size: 22rpx;
  color: #9CA3AF;
  line-height: 1.55;
}

/* 否决弹窗 */
.reject-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 10002;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 40rpx;
  box-sizing: border-box;
}
.reject-modal {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 36rpx 32rpx;
  box-sizing: border-box;
}
.reject-modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #C0392B;
  text-align: center;
  margin-bottom: 24rpx;
  line-height: 1.4;
}
.reject-modal-msg {
  display: block;
  font-size: 28rpx;
  color: #374151;
  line-height: 1.65;
  margin-bottom: 36rpx;
}
.reject-modal-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}
.reject-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.reject-btn-outline {
  border: 2rpx solid #003060;
  color: #003060;
  background: #fff;
}
.reject-btn-danger {
  background: #C0392B;
  color: #fff;
  font-weight: 600;
}

/* 底部导航（抬高至自定义 tabBar 之上，tabBar 约 100rpx + 安全区） */
.bottom-nav {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(120rpx + constant(safe-area-inset-bottom));
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #fff;
  border-top: 1rpx solid #E0E8F0;
  box-shadow: 0 -4rpx 16rpx rgba(0, 48, 96, 0.06);
  z-index: 10001;
}
.nav-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  min-height: 72rpx;
  min-width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.nav-btn-prev { border: 2rpx solid #003060; color: #003060; background: #fff; }
.nav-btn-next { background: #003060; color: #fff; }
.nav-btn-disabled { background: #B0BEC5 !important; color: #fff !important; }
.bottom-nav--single { justify-content: flex-end; }
.nav-btn-next-only { min-width: 200rpx; }
.nav-page-num { font-size: 24rpx; color: #999; flex: 1; text-align: center; }

/* 底部署名 */
.footer-credit {
  text-align: center;
  font-size: 20rpx;
  color: #bbb;
  padding-bottom: calc(240rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(240rpx + env(safe-area-inset-bottom));
}
.footer-credit-p0 {
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}
