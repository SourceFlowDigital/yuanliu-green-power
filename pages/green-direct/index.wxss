@import "/styles/shell.wxss";

.policy-tag-bar {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 18rpx 32rpx 10rpx;
}

.policy-tag {
  background: #D9EAF3;
  color: #003060;
  border-radius: 4rpx;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  line-height: 1.5;
}

.policy-tag-sub {
  color: #6B7280;
  font-size: 22rpx;
  line-height: 1.5;
}

.step-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx 12rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #DCE5EF;
  color: #6B7280;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  flex-shrink: 0;
}

.step-dot.active {
  background: #003060;
  color: #fff;
}

.step-line {
  flex: 1;
  height: 2rpx;
  background: #DCE5EF;
  max-width: 60rpx;
}

.step-card {
  margin-bottom: 0;
  background: #FFFFFF;
  border-radius: 12rpx;
  border: 1rpx solid #DCE5EF;
  border-left: 8rpx solid #7AAFD4;
  box-shadow: 0 4rpx 18rpx rgba(0, 48, 96, 0.045);
}

.step-card-header {
  align-items: center;
  justify-content: flex-start;
  margin-bottom: 8rpx;
}

.card-step-label {
  flex-shrink: 0;
  color: #003060;
  background: #D9EAF3;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1.4;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
}

.step-card-title {
  margin-bottom: 0;
}

.input-row {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(220, 229, 239, 0.9);
}

.input-row-last {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.input-label {
  display: block;
  font-size: 26rpx;
  color: #1F2933;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.input-field {
  width: 100%;
  height: 72rpx;
  background: #F4F8FB;
  border: 1rpx solid #DCE5EF;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1F2933;
  box-sizing: border-box;
}

.radio-group {
  display: flex;
  gap: 16rpx;
}

.radio-item {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  border: 1rpx solid #DCE5EF;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #6B7280;
  background: #F4F8FB;
  box-sizing: border-box;
}

.radio-item.active {
  border-color: #003060;
  background: #003060;
  color: #fff;
  font-weight: 600;
}

.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 12rpx 28rpx;
  border: 1rpx solid #DCE5EF;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #6B7280;
  background: #F4F8FB;
  box-sizing: border-box;
}

.tag-item.active {
  border-color: #003060;
  background: #003060;
  color: #fff;
  font-weight: 600;
}

.action-bar {
  padding: 10rpx 32rpx 40rpx;
}

.btn-primary {
  width: 100%;
  height: 88rpx;
  margin: 0;
  background: #003060;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 48, 96, 0.22);
}

.btn-primary::after {
  border: none;
}
