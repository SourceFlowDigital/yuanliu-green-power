@import "../../styles/shell.wxss";

.detail-page {
  min-height: 100vh;
  padding: 20rpx 28rpx calc(124rpx + env(safe-area-inset-bottom));
  background: #F4F8FB;
  box-sizing: border-box;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #003060;
  font-size: 56rpx;
  font-weight: 400;
  margin-left: 8rpx;
}

.detail-header-title {
  margin-left: 8rpx;
}

.detail-card {
  background: #FFFFFF;
  border: 1rpx solid #D9E8FF;
  border-radius: 8rpx;
  padding: 34rpx 28rpx;
  box-shadow: 0 4rpx 18rpx rgba(0, 48, 96, 0.05);
}

.detail-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.detail-tag {
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 16rpx;
  border-radius: 6rpx;
  background: #F7EBD0;
  color: #8C6720;
  font-size: 22rpx;
}

.detail-date,
.detail-source {
  color: #8A96A3;
  font-size: 24rpx;
}

.detail-title {
  color: #003060;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.42;
  margin-bottom: 18rpx;
}

.detail-source {
  margin-bottom: 28rpx;
}

.detail-summary {
  color: #374151;
  font-size: 28rpx;
  line-height: 1.75;
  margin-bottom: 36rpx;
}

.open-btn {
  height: 84rpx;
  border-radius: 8rpx;
  background: #003060;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.state-box {
  min-height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A96A3;
  font-size: 26rpx;
  text-align: center;
}
