@import "../../styles/shell.wxss";

.detail-page {
  min-height: 100vh;
  padding: 20rpx 28rpx calc(124rpx + env(safe-area-inset-bottom));
  background: #F4F8FB;
  box-sizing: border-box;
}

.back-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #003060;
  font-size: 56rpx;
  font-weight: 400;
  margin-left: 8rpx;
}

.detail-header-title {
  margin-left: 8rpx;
}

.header-logo {
  width: 156rpx;
  height: 156rpx;
  margin-right: 30rpx;
}

.detail-card {
  background: #FFFFFF;
  border: 1rpx solid #D9E8FF;
  border-radius: 8rpx;
  padding: 34rpx 28rpx;
  box-shadow: 0 4rpx 18rpx rgba(0, 48, 96, 0.05);
}

.detail-meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.detail-tag {
  height: 36rpx;
  line-height: 36rpx;
  padding: 0 16rpx;
  border-radius: 6rpx;
  background: #F7EBD0;
  color: #8C6720;
  font-size: 22rpx;
}

.detail-date,
.detail-source {
  color: #8A96A3;
  font-size: 24rpx;
}

.detail-title {
  color: #003060;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 1.42;
  margin-bottom: 18rpx;
}

.detail-source {
  margin-bottom: 28rpx;
}

.detail-summary {
  color: #374151;
  font-size: 28rpx;
  line-height: 1.75;
  margin-bottom: 36rpx;
}

.excerpt-card {
  background: #F8FAFB;
  border-left: 4rpx solid #003060;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  border-radius: 8rpx;
}

.excerpt-label {
  font-size: 24rpx;
  color: #003060;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.excerpt-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  display: block;
}

.keyword-bar {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
  gap: 12rpx;
}

.keyword-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.keyword-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.keyword-tag {
  font-size: 22rpx;
  color: #003060;
  background: #E8F0F8;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.ai-block {
  margin-bottom: 24rpx;
}

.ai-block-head {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 12rpx;
}

.ai-block-mark {
  width: 6rpx;
  height: 28rpx;
  background: #003060;
  border-radius: 3rpx;
  margin-right: 12rpx;
}

.ai-block-title {
  font-size: 28rpx;
  color: #003060;
  font-weight: bold;
}

.ai-block-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.7;
}

.ai-disclaimer {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #999;
  line-height: 1.55;
}

.open-btn {
  height: 84rpx;
  border-radius: 8rpx;
  background: #003060;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
}

.state-box {
  min-height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A96A3;
  font-size: 26rpx;
  text-align: center;
}
