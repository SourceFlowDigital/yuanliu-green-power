<view class="header">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="header-main" style="height: {{navBarHeight}}px;">
    <image class="header-logo" src="/assets/logo.png" mode="aspectFit"></image>
    <view class="header-title-group">
      <view class="header-title">源流绿电直连</view>
      <view class="header-sub-wrap">
        <text class="header-sub">绿电直连政策与行业动态</text>
      </view>
    </view>
  </view>
</view>

<view class="news-page" style="margin-top: {{headerHeight}}px;">
  <view class="category-tabs">
    <view
      wx:for="{{tabs}}"
      wx:key="value"
      class="category-tab {{activeCategory === item.value ? 'category-tab-active' : ''}}"
      data-value="{{item.value}}"
      bindtap="onTabTap"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="news-list" wx:if="{{list.length}}">
    <view
      wx:for="{{list}}"
      wx:key="id"
      class="news-card"
      data-id="{{item.id}}"
      bindtap="onCardTap"
    >
      <view class="news-card-top">
        <text class="news-tag">{{item.category}}</text>
        <text class="news-date">{{item.pub_date}}</text>
      </view>
      <view class="news-title">{{item.title}}</view>
      <view class="news-meta">{{item.source}}</view>
      <view class="news-summary">{{item.summary}}</view>
    </view>
  </view>

  <view class="state-box" wx:if="{{!loading && !list.length}}">
    <text>{{errorText || '暂无资讯，请稍后再试'}}</text>
  </view>

  <view class="loading-text" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="loading-text" wx:if="{{!loading && list.length && finished}}">
    <text>已加载全部资讯</text>
  </view>
</view>

<view class="consent-mask" wx:if="{{!userConsent}}">
  <view class="consent-modal">
    <view class="consent-title">欢迎使用源流绿电直连</view>
    <view class="consent-desc">
      <text>本工具基于发改能源〔2026〕688号，提供绿电直连项目数据测算与AI辅助风险分析服务。</text>
    </view>
    <view class="consent-desc">
      <text>使用前请阅读并同意以下协议：</text>
    </view>
    <view class="consent-links">
      <navigator url="/pages/legal/terms/terms" class="consent-link">《用户服务协议》</navigator>
      <navigator url="/pages/legal/privacy/privacy" class="consent-link">《隐私政策》</navigator>
    </view>
    <view class="consent-info">
      <text>· 我们收集您填写的项目数据用于AI分析</text>
      <text>· 不收集通讯录、相册、位置等个人信息</text>
      <text>· 测算结果仅供参考，不构成审批意见</text>
    </view>
    <view class="consent-actions">
      <view class="consent-btn consent-btn-deny" bindtap="onDenyConsent">不同意</view>
      <view class="consent-btn consent-btn-agree" bindtap="onAgreeConsent">同意并继续</view>
    </view>
  </view>
</view>
