@import "../../styles/shell.wxss";

.news-page {
  min-height: 100vh;
  padding: 20rpx 28rpx calc(124rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  background: #F4F8FB;
}

.category-tabs {
  display: flex;
  flex-direction: row;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.category-tab {
  min-width: 116rpx;
  height: 60rpx;
  padding: 0 24rpx;
  border-radius: 8rpx;
  border: 1rpx solid #D8E5F2;
  background: #FFFFFF;
  color: #6B7280;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.category-tab-active {
  color: #003060;
  border-color: #D6A84F;
  background: #FFF8E8;
  font-weight: 700;
}

.news-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.news-card {
  background: #FFFFFF;
  border: 1rpx solid #D9E8FF;
  border-radius: 8rpx;
  padding: 26rpx 24rpx;
  box-shadow: 0 4rpx 18rpx rgba(0, 48, 96, 0.05);
}

.news-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.news-tag {
  height: 34rpx;
  line-height: 34rpx;
  padding: 0 14rpx;
  border-radius: 6rpx;
  background: #F7EBD0;
  color: #8C6720;
  font-size: 22rpx;
}

.news-date,
.news-meta {
  color: #8A96A3;
  font-size: 22rpx;
}

.news-title {
  color: #003060;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.45;
  margin-bottom: 12rpx;
}

.news-meta {
  margin-bottom: 12rpx;
}

.news-summary {
  color: #4B5563;
  font-size: 25rpx;
  line-height: 1.65;
}

.state-box {
  min-height: 360rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8A96A3;
  font-size: 26rpx;
  text-align: center;
}

.loading-text {
  text-align: center;
  color: #9CA3AF;
  font-size: 24rpx;
  padding: 28rpx 0;
}

/* 隐私授权弹窗 */
.consent-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 20000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}
.consent-modal {
  width: 100%;
  max-width: 620rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 44rpx 36rpx 36rpx;
  box-sizing: border-box;
}
.consent-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #003060;
  text-align: center;
  margin-bottom: 24rpx;
  line-height: 1.4;
}
.consent-desc {
  margin-bottom: 12rpx;
}
.consent-desc text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.65;
}
.consent-links {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin: 24rpx 0;
}
.consent-link {
  font-size: 28rpx;
  color: #003060;
  text-decoration: underline;
  font-weight: 600;
}
.consent-info {
  background: #F8FAFC;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 32rpx;
}
.consent-info text {
  display: block;
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.7;
}
.consent-actions {
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}
.consent-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}
.consent-btn-deny {
  border: 2rpx solid #CCCCCC;
  color: #6B7280;
  background: #fff;
}
.consent-btn-agree {
  background: #003060;
  color: #fff;
}
