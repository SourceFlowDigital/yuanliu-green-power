<view class="header">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="header-main" style="height: {{navBarHeight}}px;">
    <image class="header-logo" src="/assets/logo.png" mode="aspectFit"></image>
    <view class="header-title-group">
      <view class="header-title">源流绿电直连</view>
      <view class="header-sub-wrap">
        <text class="header-sub">项目数据测算与风险分析工具</text>
      </view>
    </view>
  </view>
</view>

<view class="report-page" style="margin-top: {{headerHeight}}px;">
  <view wx:if="{{hasReport}}">
    <view class="report-hero">
      <text class="report-hero-title">源流绿电直连 · 项目测算报告</text>
      <text class="report-hero-sub">基于发改能源〔2026〕688号</text>
      <text class="report-hero-time">生成时间：{{generateTimeStr}}</text>
    </view>

    <view class="report-body">
      <view class="report-card">
        <view class="report-card-title">项目基本信息</view>
        <text class="report-line">项目名称：{{report.projectName}}</text>
        <text class="report-line">项目类型：{{report.projectTypeLabel}}</text>
        <text class="report-line">所在省份：{{report.province || '—'}}</text>
        <text class="report-line">目标投产年份：{{report.targetYearLabel}}</text>
        <text class="report-line">用电用户数：{{report.userCount}} 个</text>
        <view class="report-tags-row">
          <text class="report-line report-line-inline">产业类型：</text>
          <text class="report-tag" wx:for="{{report.industryTagLabels}}" wx:key="*this">{{item}}</text>
          <text class="report-line-muted" wx:if="{{!report.industryTagLabels.length}}">未填写</text>
        </view>
        <text class="report-line">年总发电量：{{report.totalGeneration}} 万kWh</text>
        <text class="report-line">年总用电量：{{report.totalConsumption}} 万kWh</text>
        <text class="report-line">自发自用电量：{{report.selfUse}} 万kWh</text>
      </view>

      <view class="section-card">
        <view class="section-title">基本条件确认</view>
        <view class="check-item">
          <text class="check-label">项目用电方均为工商业法人实体（不含居民或农业用户）</text>
          <text class="check-value {{preCheck.q1 ? 'check-yes' : 'check-no'}}">
            {{preCheck.q1 ? '✅ 是' : '❌ 否'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">项目用电方有2个或以上独立法人实体</text>
          <text class="check-value {{preCheck.q2 ? 'check-yes' : 'check-no'}}">
            {{preCheck.q2 ? '✅ 是' : '❌ 否'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">项目发电电源包含风电、光伏或生物质等新能源</text>
          <text class="check-value {{preCheck.q3 ? 'check-yes' : 'check-no'}}">
            {{preCheck.q3 ? '✅ 是' : '❌ 否'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">项目主责单位不是公共电网企业</text>
          <text class="check-value {{preCheck.q4 ? 'check-yes' : 'check-no'}}">
            {{preCheck.q4 ? '✅ 是' : '❌ 否'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">项目已成立或拟成立具备独立法人资格的主责单位</text>
          <text class="check-value {{preCheck.q5 ? 'check-yes' : 'check-no'}}">
            {{preCheck.q5 ? '✅ 是' : '❌ 否'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">项目符合国家产业政策，不涉及违法违规活动</text>
          <text class="check-value {{preCheck.q6 ? 'check-yes' : 'check-no'}}">
            {{preCheck.q6 ? '✅ 是' : '❌ 否'}}
          </text>
        </view>
      </view>

      <view class="section-card">
        <view class="section-title">注意事项确认</view>
        <view class="check-item">
          <text class="check-label">风电/光伏规模是否已纳入或计划申报省级新能源开发建设方案</text>
          <text class="check-value {{suspectCheck.q1 == 'yes' ? 'check-yes' : (suspectCheck.q1 == 'no' ? 'check-no' : 'check-neutral')}}">
            {{suspectCheck.q1 == 'yes' ? '✅ 是' : suspectCheck.q1 == 'no' ? '❌ 否' : suspectCheck.q1 == 'uncertain' ? '❓ 不确定' : '➖ 不适用'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">并网型项目是否能在消纳困难时段保证不向电网反送电</text>
          <text class="check-value {{suspectCheck.q2 == 'yes' ? 'check-yes' : (suspectCheck.q2 == 'no' ? 'check-no' : 'check-neutral')}}">
            {{suspectCheck.q2 == 'yes' ? '✅ 是' : suspectCheck.q2 == 'no' ? '❌ 否' : suspectCheck.q2 == 'notapply' ? '➖ 不适用' : '— 未填写'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">项目现有购电方式是否为直接市场交易（非电网代理购电）</text>
          <text class="check-value {{suspectCheck.q3 == 'yes' ? 'check-yes' : (suspectCheck.q3 == 'no' ? 'check-no' : 'check-neutral')}}">
            {{suspectCheck.q3 == 'yes' ? '✅ 是' : suspectCheck.q3 == 'no' ? '❌ 否' : suspectCheck.q3 == 'nopower' ? '➖ 不适用' : '— 未填写'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">涉及存量新能源：该项目是否尚未并网或存在消纳受限问题</text>
          <text class="check-value {{suspectCheck.q4 == 'yes' ? 'check-yes' : (suspectCheck.q4 == 'no' ? 'check-no' : 'check-neutral')}}">
            {{suspectCheck.q4 == 'yes' ? '✅ 是' : suspectCheck.q4 == 'no' ? '❌ 否' : suspectCheck.q4 == 'notapply' ? '➖ 不适用' : '— 未填写'}}
          </text>
        </view>
        <view class="check-item">
          <text class="check-label">涉及分布式光伏：是否拟采用集中汇流方式参与直连</text>
          <text class="check-value {{suspectCheck.q5 == 'yes' ? 'check-yes' : (suspectCheck.q5 == 'no' ? 'check-no' : 'check-neutral')}}">
            {{suspectCheck.q5 == 'yes' ? '✅ 是' : suspectCheck.q5 == 'no' ? '❌ 否' : suspectCheck.q5 == 'notapply' ? '➖ 不适用' : '— 未填写'}}
          </text>
        </view>
      </view>

      <view class="section-card">
        <view class="section-card-title">用电端详情</view>
        <view class="section-list-item" wx:for="{{users}}" wx:for-item="user" wx:for-index="uIdx" wx:key="index">
          <view class="section-row">
            <text class="section-label">用户名称</text>
            <text class="section-value">{{user.displayName}}</text>
          </view>
          <view class="section-row">
            <text class="section-label">所属行业</text>
            <text class="section-value">{{user.industryText}}</text>
          </view>
          <view class="section-row">
            <text class="section-label">年用电量</text>
            <text class="section-value">{{user.annualConsumption}} 万kWh</text>
          </view>
          <view class="section-row" wx:if="{{user.consumption2030}}">
            <text class="section-label">2030年预测用电量</text>
            <text class="section-value">{{user.consumption2030}} 万kWh</text>
          </view>
          <view class="section-row">
            <text class="section-label">屋顶光伏意向</text>
            <text class="section-value rooftop-yes" wx:if="{{user.hasRooftop}}">有意向</text>
            <text class="section-value rooftop-no" wx:else>暂无</text>
          </view>
          <block wx:if="{{user.hasRooftop}}">
            <view class="section-row">
              <text class="section-label">预计可安装容量</text>
              <text class="section-value">{{user.rooftopCapacity}} MW</text>
            </view>
            <view class="section-row">
              <text class="section-label">年有效发电小时数</text>
              <text class="section-value">{{user.rooftopHours}} h</text>
            </view>
            <view class="section-row">
              <text class="section-label">预计年发电量</text>
              <text class="section-value">{{user.rooftopGeneration}} 万kWh</text>
            </view>
          </block>
        </view>
        <text class="section-empty" wx:if="{{!users.length}}">暂无用电用户数据</text>
      </view>

      <view class="section-card">
        <view class="section-card-title">发电端详情</view>
        <view class="section-list-item" wx:for="{{energySources}}" wx:for-item="es" wx:key="index">
          <view class="section-row">
            <text class="section-label">电源类型</text>
            <text class="section-value">{{es.typeLabel}}</text>
          </view>
          <view class="section-row">
            <text class="section-label">装机容量</text>
            <text class="section-value">{{es.capacity}} MW</text>
          </view>
          <view class="section-row">
            <text class="section-label">年有效小时数</text>
            <text class="section-value">{{es.annualHours}} h</text>
          </view>
          <view class="section-row">
            <text class="section-label">年发电量</text>
            <text class="section-value">{{es.annualGeneration}} 万kWh</text>
          </view>
          <view class="section-row">
            <text class="section-label">项目状态</text>
            <text class="section-value">{{es.projectStatusLabel}}</text>
          </view>
        </view>
        <text class="section-empty" wx:if="{{!energySources.length}}">暂无电源数据</text>
      </view>

      <view class="section-card">
        <view class="section-card-title">储能配置</view>
        <block wx:if="{{hasStorage}}">
          <view class="section-row">
            <text class="section-label">储能功率</text>
            <text class="section-value">{{storagePower}} MW</text>
          </view>
          <view class="section-row">
            <text class="section-label">储能容量</text>
            <text class="section-value">{{storageCapacity}} MWh</text>
          </view>
          <view class="section-row">
            <text class="section-label">日充放次数</text>
            <text class="section-value">{{storageCycles}} 次/天</text>
          </view>
          <view class="section-row">
            <text class="section-label">年运行天数</text>
            <text class="section-value">{{storagedays}} 天</text>
          </view>
          <view class="section-row">
            <text class="section-label">年储能增量</text>
            <text class="section-value">{{annualStorageEnergy}} 万kWh</text>
          </view>
        </block>
        <text class="section-empty" wx:else>本项目未配置储能</text>
      </view>

      <view class="section-card">
        <view class="section-card-title">源荷平衡</view>
        <view class="section-row">
          <text class="section-label">总发电量</text>
          <text class="section-value">{{report.totalGeneration}} 万kWh</text>
        </view>
        <view class="section-row">
          <text class="section-label">总用电量</text>
          <text class="section-value">{{report.totalConsumption}} 万kWh</text>
        </view>
        <view class="section-row">
          <text class="section-label">自发自用电量</text>
          <text class="section-value">{{report.selfUse}} 万kWh</text>
        </view>
        <view class="section-row">
          <text class="section-label">缺口/盈余</text>
          <text class="section-value">{{gap}} 万kWh（{{report.gapTypeLabel}}）</text>
        </view>
      </view>

      <view class="report-card">
        <view class="report-card-title">三项核心指标</view>
        <view class="report-metrics">
          <view class="report-metric-item">
            <text class="report-metric-name">指标一</text>
            <text class="report-metric-desc">自发自用/总发电量</text>
            <text class="report-metric-val {{report.ratio1Pass ? 'pass' : 'fail'}}">{{report.ratio1}}%</text>
            <text class="report-metric-threshold">门槛 ≥60%</text>
            <text class="report-metric-status {{report.ratio1Pass ? 'pass' : 'fail'}}">{{report.ratio1Pass ? '✅ 满足门槛' : '❌ 不满足门槛'}}</text>
          </view>
          <view class="report-metric-item">
            <text class="report-metric-name">指标二</text>
            <text class="report-metric-desc">自发自用/总用电量</text>
            <text class="report-metric-val {{report.ratio2Pass ? 'pass' : 'fail'}}">{{report.ratio2}}%</text>
            <text class="report-metric-threshold">门槛 ≥{{report.ratio2Threshold}}%</text>
            <text class="report-metric-status {{report.ratio2Pass ? 'pass' : 'fail'}}">{{report.ratio2Pass ? '✅ 满足门槛' : '❌ 不满足门槛'}}</text>
          </view>
          <view class="report-metric-item" wx:if="{{!report.isOffgrid}}">
            <text class="report-metric-name">指标三</text>
            <text class="report-metric-desc">上网电量/总发电量</text>
            <text class="report-metric-val {{report.ratio3Pass ? 'pass' : 'fail'}}">{{report.ratio3}}%</text>
            <text class="report-metric-threshold">门槛 ≤20%</text>
            <text class="report-metric-status {{report.ratio3Pass ? 'pass' : 'fail'}}">{{report.ratio3Pass ? '✅ 满足门槛' : '❌ 不满足门槛'}}</text>
          </view>
        </view>
      </view>

      <view class="report-conclusion {{report.overallPass ? 'pass' : 'fail'}}">
        <text wx:if="{{report.overallPass}}">✅ 三项指标均满足688号文门槛要求</text>
        <text wx:else>⚠️ 存在指标未满足门槛，建议调整后重新测算</text>
      </view>

      <view class="report-card" wx:if="{{!report.overallPass && report.suggestions.length}}">
        <view class="report-card-title">💡 优化建议</view>
        <text class="report-suggest-item" wx:for="{{report.suggestions}}" wx:key="index">{{item.index}}. {{item.text}}</text>
      </view>

      <view class="report-card" wx:if="{{report.suspectWarnings.length}}">
        <view class="report-card-title">⚠️ 待落实事项</view>
        <text class="report-warn-item" wx:for="{{report.suspectWarnings}}" wx:key="key">⚠️ {{item.warnMsg}}</text>
      </view>

      <view class="copy-btn" catchtap="onCopyReport">
        <text>📋 一键复制报告内容</text>
      </view>

      <view wx:if="{{aiPaid}}" class="invoice-entry">
        <view class="invoice-entry-btn" catchtap="onApplyInvoice">🧾 申请发票</view>
      </view>

      <view class="report-ai-card">
        <text class="report-ai-title">🤖 AI深度分析报告</text>
        <text class="report-ai-desc">在基础报告基础上，增加基于688号文的专业政策解读和项目优化建议</text>
        <view class="report-sample-link" catchtap="onOpenSampleReport">查看示例报告</view>
        <view class="report-ai-pay-row" wx:if="{{!aiPaid}}">
          <text class="report-ai-price">¥19.9 / 次</text>
          <view class="report-ai-btn report-ai-btn-pay" catchtap="onContactAI">立即购买 AI 分析</view>
        </view>
        <view class="report-ai-pay-row" wx:else>
          <view class="report-ai-btn report-ai-btn-active" catchtap="onDoAIAnalyze">生成 AI 分析报告</view>
        </view>
        <view class="refund-entry" wx:if="{{pendingTradeNo && aiPaid && !aiResult && !aiLoading}}" catchtap="onRefundApply">
          <text class="refund-entry-text">已付款但未收到报告？申请退款</text>
        </view>
        <view class="report-ai-result" wx:if="{{aiLoading}}">
          <text class="report-ai-loading">AI 分析中，请稍候...</text>
        </view>
        <view class="report-ai-result" wx:elif="{{aiResult}}">
          <rich-text class="report-ai-content" nodes="{{aiResultHtml}}"></rich-text>
          <view class="report-ai-btn report-ai-btn-pdf" catchtap="onDownloadPDF">下载 PDF 分析报告</view>
        </view>
      </view>

      <view class="report-footer">
        <text>源流 · 基于发改能源〔2026〕688号</text>
        <text class="report-footer-note">仅供参考，不构成法律意见</text>
      </view>
    </view>
  </view>

  <view wx:else class="report-empty-page">
    <view class="report-empty-logo">
      <image src="/assets/logo.png" class="empty-logo-img" mode="aspectFit"/>
    </view>
    <view class="report-empty-title">源流绿电直连</view>
    <view class="report-empty-subtitle">项目数据测算与风险分析工具</view>
    <view class="report-empty-icon">📋</view>
    <view class="report-empty-desc">完成项目自测后</view>
    <view class="report-empty-desc">您的项目报告将在此展示</view>
    <view class="report-empty-btn" catchtap="onGoToCheck">立即开始自测</view>
  </view>

  <view class="sample-report-mask" wx:if="{{showSampleReport}}" catchtouchmove="noop">
    <view class="sample-report-close" catchtap="onCloseSampleReport">×</view>
    <swiper
      class="sample-report-swiper"
      current="{{sampleReportIndex}}"
      bindchange="onSampleReportChange"
      duration="260"
      circular="{{false}}"
    >
      <swiper-item wx:for="{{sampleReportImages}}" wx:key="*this" class="sample-report-item">
        <image class="sample-report-image" src="{{item}}" mode="aspectFit"></image>
      </swiper-item>
    </swiper>
    <view class="sample-report-page">{{sampleReportIndex + 1}}/{{sampleReportImages.length}}</view>
  </view>

  <view wx:if="{{showRefundModal}}" class="refund-modal-mask">
    <view class="refund-modal">
      <view class="refund-modal-title">申请退款</view>
      <view class="refund-modal-content">
        由于 AI 服务繁忙，您的报告暂时无法生成。如需申请退款，请将以下信息发送至：
      </view>
      <view class="refund-modal-email">contact@sourceflower.com</view>
      <view class="refund-modal-label">退款原因：AI服务繁忙，报告未生成</view>
      <view class="refund-modal-tradeno">
        订单号：{{pendingTradeNo || '加载中...'}}
      </view>
      <view class="refund-modal-tip">我们将在 1-3 个工作日内处理您的退款申请。</view>
      <view class="refund-modal-btns">
        <button class="refund-btn-copy" bindtap="onCopyTradeNo">复制订单号</button>
        <button class="refund-btn-close" bindtap="onCloseRefundModal">关闭</button>
      </view>
    </view>
  </view>

  <view wx:if="{{showSwitchingModal}}" class="switching-modal-mask">
    <view class="switching-modal">
      <view class="switching-spinner"></view>
      <view class="switching-text">正在切换备用模型，请稍候...</view>
      <view class="switching-tip">通常需要 10-20 秒</view>
    </view>
  </view>
</view>
