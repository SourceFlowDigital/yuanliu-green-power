@import "../../styles/shell.wxss";

page {
  background: #F4F8FB;
  font-family: "PingFang SC", -apple-system, sans-serif;
}

.report-page {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.report-empty {
  padding: 120rpx 48rpx;
  text-align: center;
}

.report-empty-text {
  font-size: 30rpx;
  color: #6B7280;
  line-height: 1.6;
}

.report-hero {
  background: #003060;
  padding: 40rpx 32rpx 48rpx;
  box-sizing: border-box;
}

.report-hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.report-hero-sub {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 16rpx;
}

.report-hero-time {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.report-body {
  padding: 24rpx;
  box-sizing: border-box;
}

.report-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 48, 96, 0.06);
}

.report-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #003060;
  margin-bottom: 20rpx;
}

.report-line {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 8rpx;
}

.report-line-inline {
  display: inline;
  margin-bottom: 0;
}

.report-line-muted {
  font-size: 26rpx;
  color: #999;
}

.report-tags-row {
  margin-bottom: 8rpx;
  line-height: 1.8;
}

.report-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #003060;
  background: #E8F0F8;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.report-metrics {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.report-metric-item {
  background: #F9FBFD;
  border-radius: 12rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.report-metric-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #003060;
}

.report-metric-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin: 8rpx 0 16rpx;
}

.report-metric-val {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 8rpx;
}

.report-metric-val.pass {
  color: #2E7D32;
}

.report-metric-val.fail {
  color: #C62828;
}

.report-metric-threshold {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.report-metric-status {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
}

.report-metric-status.pass {
  color: #2E7D32;
}

.report-metric-status.fail {
  color: #C62828;
}

.report-conclusion {
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.5;
  text-align: center;
  box-sizing: border-box;
}

.report-conclusion.pass {
  background: #E8F5E9;
  color: #2E7D32;
}

.report-conclusion.fail {
  background: #FFEBEE;
  color: #C62828;
}

.report-suggest-item,
.report-warn-item {
  display: block;
  font-size: 26rpx;
  color: #444;
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.report-warn-item:last-child,
.report-suggest-item:last-child {
  margin-bottom: 0;
}

.copy-btn {
  background-color: #003060;
  color: #fff;
  border-radius: 8px;
  padding: 14px;
  margin: 16px 16px 8px;
  text-align: center;
  font-size: 15px;
  box-sizing: border-box;
}

.copy-btn text {
  color: #fff;
  font-size: 15px;
}

.report-ai-card {
  background: #FFF8E7;
  border-left: 3rpx solid #D6A84F;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.report-ai-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #5C4A1E;
  margin-bottom: 12rpx;
}

.report-ai-desc {
  display: block;
  font-size: 26rpx;
  color: #5C4A1E;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.report-ai-btn {
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background: #D6A84F;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 12rpx;
}

.report-footer {
  text-align: center;
  padding: 16rpx 0 32rpx;
}

.report-footer text {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  line-height: 1.6;
}

.report-footer-note {
  margin-top: 8rpx;
  font-size: 20rpx !important;
}

/* T14 用电/发电/储能/源荷详情区块 */
.section-card {
  background: #fff;
  border-radius: 16rpx;
  border-left: 8rpx solid #003060;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 8rpx rgba(0, 48, 96, 0.08);
}

.section-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #003060;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #003060;
  margin-bottom: 20rpx;
}

.check-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F4F8;
}
.check-item:last-child {
  border-bottom: none;
}
.check-label {
  font-size: 26rpx;
  color: #374151;
  flex: 1;
  line-height: 1.5;
  padding-right: 16rpx;
}
.check-value {
  font-size: 26rpx;
  font-weight: 600;
  white-space: nowrap;
}
.check-yes { color: #1a7c6e; }
.check-no { color: #DC2626; }
.check-neutral { color: #6B7280; }

.section-list-item {
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid #E8EEF2;
}

.section-list-item:last-child {
  padding-bottom: 0;
  margin-bottom: 0;
  border-bottom: none;
}

.section-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.section-row:last-child {
  margin-bottom: 0;
}

.section-label {
  flex-shrink: 0;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.section-value {
  flex: 1;
  text-align: right;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  line-height: 1.5;
}

.section-value.rooftop-yes {
  color: #1a7c6e;
  font-weight: 600;
}

.section-value.rooftop-no {
  color: #999;
  font-weight: 400;
}

.section-empty {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}
