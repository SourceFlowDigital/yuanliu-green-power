<view class="header">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="header-main" style="height: {{navBarHeight}}px;">
    <image class="header-logo" src="/assets/logo.png" mode="aspectFit"></image>
    <view class="header-title-group">
      <view class="header-title">源流绿电直连</view>
      <view class="header-sub-wrap">
        <text class="header-sub">项目数据测算与风险分析工具</text>
      </view>
    </view>
  </view>
</view>

<view class="service-page" style="margin-top: {{headerHeight}}px;">
  <view class="service-card">
    <text class="service-card-title">📋 我的报告</text>
    <text class="service-card-sub">点击查看本次自测完整报告</text>
    <text wx:if="{{!reportText}}" class="service-empty-tip">暂无报告，请先完成自测</text>
    <block wx:if="{{reportText}}">
      <view class="service-toggle-btn" bindtap="onToggleReport">{{reportExpanded ? '收起' : '展开'}}</view>
      <text wx:if="{{reportExpanded}}" class="service-report-text">{{reportText}}</text>
    </block>
  </view>

  <view class="service-card">
    <text class="service-card-title">⚡ AI解读</text>
    <text class="service-card-sub">基于688号文，AI辅助分析您的项目测算结果</text>
    <text wx:if="{{!reportText}}" class="service-empty-tip">请先完成自测后再使用AI解读</text>
    <block wx:if="{{reportText}}">
      <view class="service-ai-disclaimer-top">
        <text class="service-ai-disclaimer-top-text">⚠️ 以下分析由AI自动生成，基于用户输入数据测算，仅供参考，不构成行政审批结论、投资建议或法律意见。最终结果以当地省级能源主管部门正式审批为准。</text>
      </view>
      <view wx:if="{{aiLoading}}" class="service-ai-loading">AI分析中，请稍候…</view>
      <view wx:if="{{aiBlocks.length && !aiLoading}}" class="service-ai-blocks">
        <view class="service-ai-disclaimer" wx:if="{{aiContent}}">
          <text class="service-ai-disclaimer-text">
            本解读由 DeepSeek V3 模型生成，仅供参考，不构成法律意见。政策适用请以主管部门最终解释为准。
          </text>
        </view>
        <block wx:for="{{aiBlocks}}" wx:for-item="block" wx:for-index="blockIdx" wx:key="blockIdx">
          <view wx:if="{{block.type === 'divider'}}" class="service-ai-divider"></view>
          <view wx:elif="{{block.type === 'heading'}}" class="service-ai-heading">{{block.text}}</view>
          <view wx:elif="{{block.type === 'text'}}" class="service-ai-text">
            <text wx:for="{{block.segments}}" wx:for-item="seg" wx:for-index="segIdx" wx:key="segIdx" class="{{seg.bold ? 'service-ai-bold' : 'service-ai-normal'}}">{{seg.text}}</text>
          </view>
          <view wx:elif="{{block.type === 'list'}}" class="service-ai-list">
            <text class="service-ai-list-dot">·</text>
            <view class="service-ai-list-content">
              <text wx:for="{{block.segments}}" wx:for-item="seg" wx:for-index="segIdx" wx:key="segIdx" class="{{seg.bold ? 'service-ai-bold' : 'service-ai-normal'}}">{{seg.text}}</text>
            </view>
          </view>
          <view wx:elif="{{block.type === 'empty'}}" class="service-ai-empty"></view>
        </block>
      </view>
      <view wx:if="{{aiError && !aiLoading}}" class="service-ai-error-wrap">
        <text class="service-ai-error">{{aiError}}</text>
        <view class="service-action-btn" bindtap="onStartAiAnalysis">重试</view>
      </view>
      <view wx:if="{{!aiLoading && !aiContent && !aiError}}" class="service-action-btn" bindtap="onStartAiAnalysis">开始AI解读</view>
    </block>
  </view>
</view>
