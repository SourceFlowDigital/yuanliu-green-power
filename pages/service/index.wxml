<view class="header">
  <view class="status-bar" style="height: {{statusBarHeight}}px;"></view>
  <view class="header-main" style="height: {{navBarHeight}}px;">
    <image class="header-logo" src="/assets/logo.png" mode="aspectFit"></image>
    <view class="header-title-group">
      <view class="header-title">源流绿电直连</view>
      <view class="header-sub-wrap">
        <text class="header-sub">政策合规自测工具</text>
      </view>
    </view>
  </view>
</view>
<view class="body" style="margin-top: {{headerHeight}}px;">
  <view class="surface-strip">
    <text class="surface-strip-tip">AI解读</text>
  </view>
  <view class="policy-list">
    <view class="policy-card ai-card">
      <view class="ai-card-title">
        <text class="iconfont-ai" style="font-size:40rpx;margin-right:8rpx;"></text>
        <text class="ai-card-title-text">AI政策解读</text>
      </view>
      <view class="ai-card-sub">基于688号文，智能解读您的项目合规情况</view>
      <button class="ai-card-btn" bindtap="onStartAi">开始AI解读</button>
    </view>
  </view>
</view>
