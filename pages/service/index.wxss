@import "../../styles/shell.wxss";

.service-page {
  padding: 24rpx;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.service-card {
  background: #fff;
  border-left: 4px solid #003060;
  border-radius: 8px;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 48, 96, 0.06);
}

.service-card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #003060;
  margin-bottom: 12rpx;
}

.service-card-sub {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.service-empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.service-toggle-btn {
  font-size: 28rpx;
  color: #003060;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.service-report-text {
  display: block;
  font-size: 13px;
  line-height: 1.8;
  color: #444;
  white-space: pre-wrap;
  word-break: break-all;
}

.service-ai-loading {
  text-align: center;
  font-size: 14px;
  color: #999;
  line-height: 1.8;
  padding: 24rpx 0;
}

.service-ai-blocks {
  width: 100%;
}

.service-ai-disclaimer-top {
  background: #FFF8E8;
  border: 1rpx solid #F0D9A8;
  border-left: 6rpx solid #D6A84F;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}
.service-ai-disclaimer-top-text {
  font-size: 24rpx;
  color: #B7791F;
  line-height: 1.65;
  display: block;
}

.service-ai-disclaimer {
  background: #f4f8fb;
  border: 1px solid #e0e0e0;
  border-radius: 8rpx;
  padding: 12rpx 24rpx 36rpx 24rpx;
  margin-bottom: 16rpx;
}

.service-ai-disclaimer-text {
  font-size: 22rpx;
  color: #888;
  line-height: 1.6;
  display: block;
}

.service-ai-divider {
  height: 1px;
  background: #e0e0e0;
  margin: 8px 0;
}

.service-ai-heading {
  font-weight: bold;
  color: #003060;
  font-size: 14px;
  margin: 4px 0;
  line-height: 1.8;
}

.service-ai-text {
  font-size: 14px;
  line-height: 1.8;
  color: #333;
  word-break: break-all;
}

.service-ai-list {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  font-size: 14px;
  line-height: 1.8;
  color: #333;
  padding-left: 12px;
  word-break: break-all;
}

.service-ai-list-dot {
  flex-shrink: 0;
  margin-right: 8px;
  color: #333;
}

.service-ai-list-content {
  flex: 1;
}

.service-ai-empty {
  height: 8px;
}

.service-ai-bold {
  font-weight: bold;
  color: #003060;
}

.service-ai-normal {
  font-weight: normal;
  color: #333;
}

.service-ai-error-wrap {
  text-align: center;
}

.service-ai-error {
  display: block;
  font-size: 14px;
  color: #E74C3C;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.service-action-btn {
  width: 100%;
  background: #003060;
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  text-align: center;
  border-radius: 8px;
  padding: 14px;
  box-sizing: border-box;
}
