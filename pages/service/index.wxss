@import "../../styles/shell.wxss";

.ai-card {
  background: #FFFFFF;
}

.ai-card-title {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 16rpx;
}

.ai-icon {
  font-size: 48rpx;
  color: #003060;
  margin-right: 12rpx;
  line-height: 1;
}

.ai-card-title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1F2933;
  line-height: 1.4;
}

.ai-card-sub {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.ai-card-btn {
  width: 100%;
  height: 88rpx;
  margin: 0;
  background: #003060;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 48, 96, 0.22);
}

.ai-card-btn::after {
  border: none;
}
