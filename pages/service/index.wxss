@import "../../styles/shell.wxss";

.service-page {
  padding: 24rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.service-card {
  background: #fff;
  border-left: 4px solid #003060;
  border-radius: 8px;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
  box-shadow: 0 2rpx 12rpx rgba(0, 48, 96, 0.06);
}

.service-card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #003060;
  margin-bottom: 12rpx;
}

.service-card-sub {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.service-empty-tip {
  display: block;
  font-size: 26rpx;
  color: #999;
  line-height: 1.6;
}

.service-toggle-btn {
  font-size: 28rpx;
  color: #003060;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.service-report-text {
  display: block;
  font-size: 13px;
  line-height: 1.8;
  color: #444;
  white-space: pre-wrap;
  word-break: break-all;
}

.service-ai-loading {
  text-align: center;
  font-size: 14px;
  color: #999;
  line-height: 1.8;
  padding: 24rpx 0;
}

.service-ai-content {
  display: block;
  font-size: 14px;
  line-height: 1.8;
  color: #333;
  white-space: pre-wrap;
  word-break: break-all;
}

.service-ai-error-wrap {
  text-align: center;
}

.service-ai-error {
  display: block;
  font-size: 14px;
  color: #E74C3C;
  line-height: 1.8;
  margin-bottom: 24rpx;
}

.service-action-btn {
  width: 100%;
  background: #003060;
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  text-align: center;
  border-radius: 8px;
  padding: 14px;
  box-sizing: border-box;
}
