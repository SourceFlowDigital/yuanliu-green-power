/* 与政策首页一致的顶栏与卡片基础（可按页 @import） */
page{background:#F4F8FB;}

.header{position:fixed;top:0;left:0;width:100%;display:flex;flex-direction:column;background:#F4F8FB;border-bottom:1rpx solid #DDE7F0;box-shadow:0 2rpx 12rpx rgba(0,48,96,0.06);z-index:999;}

.status-bar{width:100%;flex-shrink:0;}

.header-main{box-sizing:border-box;width:100%;flex-shrink:0;display:flex;flex-direction:row;align-items:center;padding:52rpx 32rpx;background:#F4F8FB;}

.header-logo{display:block;width:156rpx;height:156rpx;margin-right:30rpx;flex-shrink:0;}

.header-title-group{flex:1;display:flex;flex-direction:column;justify-content:center;min-width:0;}

.header-title{display:inline-block;vertical-align:middle;font-size:44rpx;font-weight:700;line-height:1.32;letter-spacing:2rpx;color:transparent;background:linear-gradient(135deg,#E8C060,#003060);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}

.header-sub{display:block;margin-top:10rpx;font-size:28rpx;line-height:1.4;color:#607086;}
.header-sub-wrap{display:flex;flex-direction:column;margin-top:10rpx;}
.header-sub-wrap .header-sub{margin-top:0;}
.header-sub-wrap .header-sub+.header-sub{margin-top:4rpx;font-size:24rpx;}

.body{background:#F4F8FB;min-height:100vh;padding-bottom:calc(180rpx + constant(safe-area-inset-bottom));padding-bottom:calc(180rpx + env(safe-area-inset-bottom));box-sizing:border-box;}

.surface-strip{background:#FFFFFF;padding:16rpx 32rpx 20rpx;border-bottom:1rpx solid #D8D8D8;}

.surface-strip-tip{font-size:24rpx;color:#6B7280;line-height:1.5;}

.policy-list{padding:20rpx 24rpx 48rpx;box-sizing:border-box;}

.policy-card{background:#F2F6FA;border-radius:18rpx;padding:26rpx 28rpx;margin-bottom:22rpx;border:1rpx solid #DCE5EF;border-left:8rpx solid #7AAFD4;box-shadow:0 4rpx 24rpx rgba(0,48,96,0.06);box-sizing:border-box;}

.card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14rpx;gap:16rpx;}

.source-tag{display:inline-block;color:#003060;background:transparent;border:none;font-size:24rpx;font-weight:500;line-height:1.4;padding:0;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}

.card-date{flex-shrink:0;margin-top:2rpx;font-size:22rpx;color:#6B7280;white-space:nowrap;}

.card-title{font-size:28rpx;font-weight:500;color:#213246;line-height:1.6;margin-bottom:16rpx;}

.card-footer{display:flex;justify-content:space-between;align-items:center;}

.region-heading{font-size:22rpx;color:#6B7280;font-weight:500;margin:12rpx 8rpx 8rpx;padding-top:8rpx;}

.region-heading:first-child{margin-top:0;padding-top:0;}

.empty,.loading{text-align:center;padding:80rpx 0;color:#6B7280;font-size:28rpx;}

.save-bar{margin:8rpx 24rpx 48rpx;}

.save-btn{width:100%;box-sizing:border-box;background:#003060;color:#fff;text-align:center;padding:28rpx;border-radius:18rpx;font-size:30rpx;font-weight:500;box-shadow:0 4rpx 16rpx rgba(0,48,96,0.25);}
.about-block{margin-bottom:22rpx;}

.about-p{font-size:26rpx;color:#5E6D7F;line-height:1.85;margin-bottom:16rpx;}
.about-strong{font-weight:600;color:#1F2933;}

